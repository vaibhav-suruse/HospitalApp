<script>
    $(document).ready(function () {

        $.ajax({
            url: '/DashBord/GetDashboardCounts',
            type: 'GET',
            success: function (data) {

                console.log("Dashboard data:", data);

              // Top Cards
    $('#totalPatients').text(data.TotalPatients);
    $('#totalAppointments').text(data.TotalAppointments);
    $("#completedAppointments").text(data.CompletedAppointments);
    $("#pendingAppointments").text(data.PendingAppointments);

    // Today
    $('#todayAppointments').text(data.TodayAppointments);
    $("#todayCompleted").text(data.TodayCompleted);
    $("#todayPending").text(data.TodayPending);
    $("#todayAvailableDoctors").text(data.TodayAvailableDoctors);

    // Yesterday
    $('#yesterdayAppointments').text(data.YesterdayAppointments);
    $("#yesterdayCompleted").text(data.YesterdayCompleted);
    $("#yesterdayPending").text(data.YesterdayPending);
    $("#yesterdayAvailableDoctors").text(data.YesterdayAvailableDoctors);

    // Tomorrow
    $('#tomorrowAppointments').text(data.TomorrowAppointments);
    $("#tomorrowCompleted").text(data.TomorrowCompleted);
    $("#tomorrowPending").text(data.TomorrowPending);
    $("#tomorrowAvailableDoctors").text(data.TomorrowAvailableDoctors);

                // =============================
                // Second Chart (Dynamic)
                // =============================
                var options2 = {
                    chart: {
                        type: 'bar',
                        height: 350
                    },
                    series: [{
                        name: 'Appointments',
                        data: [
                            data.WeeklyAppointments,
                            data.MonthlyAppointments,
                            data.YearlyAppointments
                        ]
                    }],
                    xaxis: {
                        categories: ['Week', 'Month', 'Year']
                    },
                    colors: ['#34c38f']
                };

                var chart2 = new ApexCharts(
                    document.querySelector("#appointment-summary-chart"),
                    options2
                );

                chart2.render();
            },
            error: function (err) {
                console.error("Error fetching dashboard data:", err);
            }
        });

    });
</script> *@