                    <strong>Death:</strong> Please ensure death certificate is issued.
                    Condition will be set to Expired automatically.
                </div>

                <hr />

                @* MEDICAL SUMMARY *
                <h5 class="text-primary mb-3">
                    <i class="fas fa-notes-medical me-2"></i>Medical Summary
                </h5>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label><strong>Final Diagnosis</strong> <span class="text-danger">*</span></label>
                        <textarea asp-for="FinalDiagnosis" class="form-control" rows="3"
                                  placeholder="Enter final diagnosis..."></textarea>
                        <span asp-validation-for="FinalDiagnosis" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label><strong>Treatment Summary</strong></label>
                        <textarea asp-for="TreatmentSummary" class="form-control" rows="3"
                                  placeholder="Brief summary of treatment given..."></textarea>
                    </div>
                </div>

                <hr />

                @* FOLLOW UP *
                <h5 class="text-primary mb-3">
                    <i class="fas fa-calendar-check me-2"></i>Follow-up
                </h5>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label><strong>Follow-up Date</strong></label>
                        <input asp-for="FollowUpDate" type="date" class="form-control"
                               min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-4">
                        <label><strong>Follow-up Doctor</strong></label>
                        <select asp-for="FollowUpDoctorId" class="form-control">
                            <option value="">-- Select Doctor --</option>
                            @foreach (var d in ViewBag.Doctors as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)
                            {
                                <option value="@d.Value">@d.Text</option>
                            }
                        </select>
                    </div>
                </div>

                <hr />

                @* DISCHARGE INSTRUCTIONS *
                <h5 class="text-primary mb-3">
                    <i class="fas fa-clipboard-list me-2"></i>Discharge Instructions
                </h5>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label><strong>Discharge Instructions</strong></label>
                        <textarea asp-for="DischargeInstructions" class="form-control" rows="3"
                                  placeholder="e.g. Take rest for 1 week..."></textarea>
                    </div>
                    <div class="col-md-6">
                        <label><strong>Diet Instructions</strong></label>
                        <textarea asp-for="DietInstructions" class="form-control" rows="3"
                                  placeholder="e.g. Avoid spicy food, take soft diet..."></textarea>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label><strong>Activity Restrictions</strong></label>
                        <textarea asp-for="ActivityRestrictions" class="form-control" rows="3"
                                  placeholder="e.g. No heavy lifting for 4 weeks..."></textarea>
                    </div>
                    <div class="col-md-6">
                        <label><strong>Special Notes</strong></label>
                        <textarea asp-for="SpecialNotes" class="form-control" rows="3"
                                  placeholder="Any special notes for patient..."></textarea>
                    </div>
                </div>

                <hr />

                @* DISCHARGE MEDICINES — INSIDE FORM, CLIENT-SIDE ADD/REMOVE *
                <h5 class="text-primary mb-3">
                    <i class="fas fa-pills me-2"></i>Discharge Medicines
                    <small class="text-muted fs-6 fw-normal">(Medicines patient will take after discharge)</small>
                </h5>

                @* ADD MEDICINE ROW *
                <div class="card border mb-3">
                    <div class="card-body">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-3">
                                <label><strong>Medicine</strong></label>
                                <select id="ddlMedicine" class="form-control">
                                    <option value="">-- Select Medicine --</option>
                                    @foreach (var m in ViewBag.Medicines as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)
                                    {
                                        <option value="@m.Value" data-name="@m.Text">@m.Text</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-1">
                                <label><strong>Dosage</strong></label>
                                <input type="text" id="txtDosage" class="form-control" placeholder="500mg" />
                            </div>
                            <div class="col-md-1">
                                <label><strong>Route</strong></label>
                                <select id="ddlRoute" class="form-control">
                                    <option value="Oral">Oral</option>
                                    <option value="IV">IV</option>
                                    <option value="IM">IM</option>
                                    <option value="Topical">Topical</option>
                                    <option value="Sublingual">Sublingual</option>
                                </select>
                            </div>
                            <div class="col-md-1 text-center">
                                <label class="d-block"><strong>M</strong></label>
                                <input type="checkbox" id="chkMorning" />
                            </div>
                            <div class="col-md-1 text-center">
                                <label class="d-block"><strong>A</strong></label>
                                <input type="checkbox" id="chkAfternoon" />
                            </div>
                            <div class="col-md-1 text-center">
                                <label class="d-block"><strong>E</strong></label>
                                <input type="checkbox" id="chkEvening" />
                            </div>
                            <div class="col-md-1">
                                <label><strong>Days</strong></label>
                                <input type="number" id="txtDays" class="form-control" min="1" placeholder="7" />
                            </div>
                            <div class="col-md-2">
                                <label><strong>Instructions</strong></label>
                                <input type="text" id="txtMedInstructions" class="form-control" placeholder="After food" />
                            </div>
                            <div class="col-md-1">
                                <button type="button" class="btn btn-primary w-100" onclick="addMedicineRow()">
                                    + Add
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                @* MEDICINE TABLE — rows have hidden inputs posted with form *
                <table class="table table-bordered mb-4" id="medicineTable">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Medicine</th>
                            <th>Dosage</th>
                            <th>M</th>
                            <th>A</th>
                            <th>E</th>
                            <th>Days</th>
                            <th>Route</th>
                            <th>Instructions</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="medicineTableBody">
                        @if (Model.DischargeMedicines != null && Model.DischargeMedicines.Any())
                        {
                            int mi = 0;
                            foreach (var med in Model.DischargeMedicines)
                            {
                                <tr id="medRow_@mi">
                                    <td>@(mi + 1)</td>
                                    <td>
                                        <strong>@med.MedicineName</strong>
                                        <input type="hidden" name="DischargeMedicines[@mi].MedicineId" value="@med.MedicineId" />
                                        <input type="hidden" name="DischargeMedicines[@mi].MedicineName" value="@med.MedicineName" />
                                    </td>
                                    <td>
                                        @(med.Dosage ?? "-")
                                        <input type="hidden" name="DischargeMedicines[@mi].Dosage" value="@med.Dosage" />
                                    </td>
                                    <td>
                                        @(med.Morning ? "✔" : "-")
                                        <input type="hidden" name="DischargeMedicines[@mi].Morning" value="@med.Morning.ToString().ToLower()" />
                                    </td>
                                    <td>
                                        @(med.Afternoon ? "✔" : "-")
                                        <input type="hidden" name="DischargeMedicines[@mi].Afternoon" value="@med.Afternoon.ToString().ToLower()" />
                                    </td>
                                    <td>
                                        @(med.Evening ? "✔" : "-")
                                        <input type="hidden" name="DischargeMedicines[@mi].Evening" value="@med.Evening.ToString().ToLower()" />
                                    </td>
                                    <td>
                                        @(med.Days.HasValue? med.Days + "d" : "-")
                                        <input type="hidden" name="DischargeMedicines[@mi].Days" value="@med.Days" />
                                    </td>
                                    <td>
                                        @(med.Route ?? "-")
                                        <input type="hidden" name="DischargeMedicines[@mi].Route" value="@med.Route" />
                                    </td>
                                    <td>
                                        @(med.Instructions ?? "-")
                                        <input type="hidden" name="DischargeMedicines[@mi].Instructions" value="@med.Instructions" />
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-danger"
                                                onclick="removeMedicineRow('medRow_@mi')">
                                            Remove
                                        </button>
                                    </td>
                                </tr>
                                mi++;
                            }
                        }
                        else
                        {
                            <tr id="noMedRow">
                                <td colspan="10" class="text-center text-muted">No medicines added yet</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <hr />

                @* DISCHARGE BUTTON *
                <div class="d-flex justify-content-end mt-3">
                    <a asp-controller="IPDAdmission"
                       asp-action="Details"
                       asp-route-id="@Model.IPDId"
                       class="btn btn-secondary me-2">Cancel</a>
                    <button type="submit" class="btn btn-danger"
                            onclick="return confirm('Are you sure you want to discharge this patient? This action cannot be undone.')">
                        <i class="fas fa-sign-out-alt me-1"></i> Discharge Patient
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>

        // Track row index for proper model binding
        var medRowIndex = @(Model.DischargeMedicines?.Count ?? 0);

        document.getElementById('dischargeTypeSelect').addEventListener('change', function () {
            var type = this.value;
            document.getElementById('lamaWarning').classList.add('d-none');
            document.getElementById('deathWarning').classList.add('d-none');
            if (type === 'LAMA') {
                document.getElementById('lamaWarning').classList.remove('d-none');
            } else if (type === 'Death') {
                document.getElementById('deathWarning').classList.remove('d-none');
                document.getElementById('conditionSelect').value = 'Expired';
            }
        });

        @if (TempData["Error"] != null)
        {
                    <text>toastr.error("@TempData["Error"]");</text>
        }

        function addMedicineRow() {
            var ddl = document.getElementById('ddlMedicine');
            var medicineId = ddl.value;
            var medicineName = ddl.options[ddl.selectedIndex]?.text ?? '';
            var dosage = document.getElementById('txtDosage').value.trim();
            var route = document.getElementById('ddlRoute').value;
            var morning = document.getElementById('chkMorning').checked;
            var afternoon = document.getElementById('chkAfternoon').checked;
            var evening = document.getElementById('chkEvening').checked;
            var days = document.getElementById('txtDays').value.trim();
            var instructions = document.getElementById('txtMedInstructions').value.trim();

            if (!medicineId) { alert('Please select a medicine'); return; }
            if (!morning && !afternoon && !evening) {
                alert('Please select at least Morning, Afternoon or Evening');
                return;
            }

            // Remove "no medicines" placeholder row if present
            var noRow = document.getElementById('noMedRow');
            if (noRow) noRow.remove();

            var idx = medRowIndex;
            var rowId = 'medRow_' + idx;

            // Count current visible rows for display number
            var currentCount = document.getElementById('medicineTableBody').rows.length + 1;

            var tr = document.createElement('tr');
            tr.id = rowId;
            tr.innerHTML =
                '<td>' + currentCount + '</td>' +
                '<td><strong>' + medicineName + '</strong>' +
                    '<input type="hidden" name="DischargeMedicines[' + idx + '].MedicineId" value="' + medicineId + '" />' +
                    '<input type="hidden" name="DischargeMedicines[' + idx + '].MedicineName" value="' + medicineName + '" />' +
                '</td>' +
                '<td>' + (dosage || '-') +
                    '<input type="hidden" name="DischargeMedicines[' + idx + '].Dosage" value="' + dosage + '" />' +
                '</td>' +
                '<td>' + (morning ? '✔' : '-') +
                    '<input type="hidden" name="DischargeMedicines[' + idx + '].Morning" value="' + morning + '" />' +
                '</td>' +
                '<td>' + (afternoon ? '✔' : '-') +
                    '<input type="hidden" name="DischargeMedicines[' + idx + '].Afternoon" value="' + afternoon + '" />' +
                '</td>' +
                '<td>' + (evening ? '✔' : '-') +
                    '<input type="hidden" name="DischargeMedicines[' + idx + '].Evening" value="' + evening + '" />' +
                '</td>' +
                '<td>' + (days ? days + 'd' : '-') +
                    '<input type="hidden" name="DischargeMedicines[' + idx + '].Days" value="' + days + '" />' +
                '</td>' +
                '<td>' + route +
                    '<input type="hidden" name="DischargeMedicines[' + idx + '].Route" value="' + route + '" />' +
                '</td>' +
                '<td>' + (instructions || '-') +
                    '<input type="hidden" name="DischargeMedicines[' + idx + '].Instructions" value="' + instructions + '" />' +
                '</td>' +
                '<td><button type="button" class="btn btn-sm btn-danger" onclick="removeMedicineRow(\'' + rowId + '\')">Remove</button></td>';

            document.getElementById('medicineTableBody').appendChild(tr);
            medRowIndex++;

            // Clear inputs
            document.getElementById('ddlMedicine').value = '';
            document.getElementById('txtDosage').value = '';
            document.getElementById('ddlRoute').value = 'Oral';
            document.getElementById('chkMorning').checked = false;
            document.getElementById('chkAfternoon').checked = false;
            document.getElementById('chkEvening').checked = false;
            document.getElementById('txtDays').value = '';
            document.getElementById('txtMedInstructions').value = '';
        }

        function removeMedicineRow(rowId) {
            var row = document.getElementById(rowId);
            if (row) row.remove();

            // If table is empty, show placeholder
            var tbody = document.getElementById('medicineTableBody');
            if (tbody.rows.length === 0) {
                tbody.innerHTML = '<tr id="noMedRow"><td colspan="10" class="text-center text-muted">No medicines added yet</td></tr>';
            }
        }

    </script>
}











 *@
