@model List<WebApplicationSampleTest2.Models.PatientIPDDetailVM>
@{
    ViewData["Title"] = "IPD History";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
}

<div class="row mb-3">
    <div class="col-12">
        <h4 class="mb-0">
            <i class="bx bx-bed text-primary me-2"></i>
            My IPD Admissions
        </h4>
        <p class="text-muted small mt-1">
            Complete hospital admission records
        </p>
    </div>
</div>

@if (Model == null || Model.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bx bx-bed font-size-48 text-muted d-block mb-2"></i>
            <p class="text-muted">No IPD admissions found.</p>
        </div>
    </div>
}
else
{
    @foreach (var ipd in Model)
    {
        <div class="card mb-4">

            <div class="card-header bg-light py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-1">
                            <i class="bx bx-clipboard text-primary me-1"></i>
                            Admission: <strong>@ipd.AdmissionNumber</strong>
                        </h6>
                        <small class="text-muted">
                            @ipd.AdmissionDateTime.ToString("dd MMM yyyy")
                            @if (ipd.DischargeDateTime.HasValue)
                            {
                                <span>→ @ipd.DischargeDateTime.Value.ToString("dd MMM yyyy")</span>
                            }
                            else
                            {
                                <span class="text-warning">→ Present</span>
                            }
                            (@ipd.TotalDays day(s))
                        </small>
                    </div>
                    @{
                        string admBadge = ipd.Status == "Admitted"
                        ? "bg-warning" : "bg-success";
                    }
                    <span class="badge @admBadge">@ipd.Status</span>
                </div>
            </div>

            <div class="card-body">

                <div class="row g-3 mb-3">
                    <div class="col-md-3 col-6">
                        <small class="text-muted d-block">Doctor</small>
                        <strong class="small">Dr. @ipd.DoctorName</strong>
                    </div>
                    <div class="col-md-3 col-6">
                        <small class="text-muted d-block">Ward</small>
                        <strong class="small">
                            @(string.IsNullOrEmpty(ipd.WardName) ? "—" : ipd.WardName)
                        </strong>
                    </div>
                    <div class="col-md-3 col-6">
                        <small class="text-muted d-block">Bed</small>
                        <strong class="small">
                            @(string.IsNullOrEmpty(ipd.BedNumber) ? "—" : ipd.BedNumber)
                        </strong>
                    </div>
                    <div class="col-md-3 col-6">
                        <small class="text-muted d-block">Reason</small>
                        <strong class="small">
                            @(string.IsNullOrEmpty(ipd.ReasonForAdmission) ? "—" : ipd.ReasonForAdmission)
                        </strong>
                    </div>
                </div>

                @if (ipd.HasBill)
                {
                    <div class="bg-light rounded p-3 mb-3">
                        <div class="row text-center">
                            <div class="col-4">
                                <small class="text-muted d-block">Total</small>
                                <strong>₹@ipd.TotalAmount.ToString("0.00")</strong>
                            </div>
                            <div class="col-4">
                                <small class="text-muted d-block">Paid</small>
                                <strong class="text-success">₹@ipd.PaidAmount.ToString("0.00")</strong>
                            </div>
                            <div class="col-4">
                                <small class="text-muted d-block">Due</small>
                                @{
                                    string dueClass = ipd.DueAmount > 0
                                    ? "text-danger" : "text-success";
                                }
                                <strong class="@dueClass">
                                    ₹@ipd.DueAmount.ToString("0.00")
                                </strong>
                            </div>
                        </div>
                        <div class="text-center mt-2">
                            @{
                                string payBadge = ipd.PaymentStatus == "Paid"
                                ? "bg-success"
                                : ipd.PaymentStatus == "Partial"
                                ? "bg-warning"
                                : "bg-danger";
                            }
                            <span class="badge @payBadge">@ipd.PaymentStatus</span>
                        </div>
                    </div>
                }

                @if (ipd.DoctorRounds != null && ipd.DoctorRounds.Count > 0)
                {
                    <h6 class="mt-3 mb-2">
                        <i class="bx bx-user-check text-primary me-1"></i>
                        Doctor Rounds
                        <span class="badge bg-primary ms-1">@ipd.DoctorRounds.Count</span>
                    </h6>

                    <div class="accordion mb-3" id="rounds_@ipd.IPDId">
                        @foreach (var round in ipd.DoctorRounds)
                        {
                            string roundCollapseId = "round_" + round.RoundId.ToString();
                            string roundParentId = "rounds_" + ipd.IPDId.ToString();

                            <div class="accordion-item border mb-2 rounded">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed py-2"
                                            type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#@roundCollapseId"
                                            aria-expanded="false"
                                            aria-controls="@roundCollapseId">
                                        <div class="d-flex align-items-center gap-2 w-100">
                                            <span class="badge bg-info text-dark">
                                                @round.RoundType
                                            </span>
                                            <span class="small">
                                                @round.RoundDateTime.ToString("dd MMM yyyy hh:mm tt")
                                            </span>
                                            <span class="text-muted small ms-auto me-3">
                                                Dr. @round.DoctorName
                                            </span>
                                            @if (round.IsAbnormal)
                                            {
                                                <span class="badge bg-danger">Abnormal</span>
                                            }
                                        </div>
                                    </button>
                                </h2>

                                <div id="@roundCollapseId"
                                     class="accordion-collapse collapse"
                                     data-bs-parent="#@roundParentId">
                                    <div class="accordion-body pt-2">

                                        @if (!string.IsNullOrEmpty(round.PatientCondition) ||
                                                                !string.IsNullOrEmpty(round.Diagnosis))
                                        {
                                            <div class="row mb-2">
                                                @if (!string.IsNullOrEmpty(round.PatientCondition))
                                                {
                                                    <div class="col-md-6">
                                                        <small class="text-muted">Condition</small>
                                                        <p class="mb-1 small">@round.PatientCondition</p>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(round.Diagnosis))
                                                {
                                                    <div class="col-md-6">
                                                        <small class="text-muted">Diagnosis</small>
                                                        <p class="mb-1 small">@round.Diagnosis</p>
                                                    </div>
                                                }
                                            </div>
                                        }

                                        @if (round.Symptoms != null && round.Symptoms.Count > 0)
                                        {
                                            <div class="mb-2">
                                                <small class="text-muted d-block mb-1">Symptoms</small>
                                                <div class="d-flex flex-wrap gap-1">
                                                    @foreach (var s in round.Symptoms)
                                                    {
                                                        <span class="badge bg-warning text-dark">
                                                            @s.SymptomName
                                                            @if (!string.IsNullOrEmpty(s.SubName))
                                                            {
                                                                <span>- @s.SubName</span>
                                                            }
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                        }

                                        @if (round.Medicines != null && round.Medicines.Count > 0)
                                        {
                                            <div class="mb-2">
                                                <small class="text-muted d-block mb-1">
                                                    Medicines Prescribed
                                                </small>
                                                <div class="table-responsive">
                                                    <table class="table table-sm table-bordered mb-0">
                                                        <thead class="table-light">
                                                            <tr>
                                                                <th>Medicine</th>
                                                                <th>Timing</th>
                                                                <th>Days</th>
                                                                <th>Dosage</th>
                                                                <th>Route</th>
                                                                <th>Status</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var med in round.Medicines)
                                                            {
                                                                <tr>
                                                                    <td class="small">
                                                                        @med.MedicineName
                                                                        @if (!string.IsNullOrEmpty(med.MedicineType))
                                                                        {
                                                                            <br />
                                                                            <small class="text-muted">
                                                                                @med.MedicineType
                                                                            </small>
                                                                        }
                                                                </td>
                                                                <td class="small">@med.TimingDisplay</td>
                                                                <td class="small">
                                                                    @(med.Days.HasValue
                                                                                                                    ? med.Days + " days"
                                                                                                                    : "—")
                                                                                                                      </td>
                                                                                                                      <td class="small">
                                                                    @(string.IsNullOrEmpty(med.Dosage)
                                                                                                                    ? "—" : med.Dosage)
                                            </td>
                                            <td class="small">@med.Route</td>
                                            <td>
                                                @{
                                                                            string medBadge = med.Status == "Active"
                                                                            ? "bg-success" : "bg-secondary";
                                                                        }
                                                                        <span class="badge @medBadge">
                                                                            @med.Status
                                                                        </span>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        }

                                        @if (round.Investigations != null &&
                                                                round.Investigations.Count > 0)
                                        {
                                            <div class="mb-2">
                                                <small class="text-muted d-block mb-1">
                                                    Investigations Ordered
                                                </small>
                                                <div class="table-responsive">
                                                    <table class="table table-sm table-bordered mb-0">
                                                        <thead class="table-light">
                                                            <tr>
                                                                <th>Test</th>
                                                                <th>Type</th>
                                                                <th>Priority</th>
                                                                <th>Status</th>
                                                                <th>Result</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var inv in round.Investigations)
                                                            {
                                                                <tr>
                                                                    <td class="small">@inv.TestName</td>
                                                                    <td class="small">@inv.InvestigationType</td>
                                                                    <td>
                                                                        @{
                                                                            string prioBadge =
                                                                            inv.Priority == "Emergency"
                                                                            ? "bg-danger"
                                                                            : inv.Priority == "Urgent"
                                                                            ? "bg-warning text-dark"
                                                                            : "bg-secondary";
                                                                        }
                                                                        <span class="badge @prioBadge">
                                                                            @inv.Priority
                                                                        </span>
                                                                    </td>
                                                                    <td>
                                                                        @{
                                                                            string invBadge =
                                                                            inv.Status == "Completed"
                                                                            ? "bg-success"
                                                                            : inv.Status == "Ordered"
                                                                            ? "bg-info text-dark"
                                                                            : "bg-secondary";
                                                                        }
                                                                    <span class="badge @invBadge">
                                                                        @inv.Status
                                                                    </span>
                                                                </td>
                                                                <td class="small">
                                                                    @(string.IsNullOrEmpty(inv.Result)
                                                                                                                    ? "Pending" : inv.Result)
                                            </td>
                                        </tr>
                                                                                }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        }

                                        @if (!string.IsNullOrEmpty(round.Notes))
                                        {
                                            <div>
                                                <small class="text-muted">Doctor Notes</small>
                                                <p class="small mb-0 fst-italic">
                                                    "@round.Notes"
                                                </p>
                                            </div>
                                        }

                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small">
                        <i class="bx bx-info-circle me-1"></i>
                        No doctor rounds recorded yet.
                    </p>
                }

                @if (ipd.Vitals != null && ipd.Vitals.Count > 0)
                {
                    <h6 class="mt-3 mb-2">
                        <i class="bx bx-heart text-danger me-1"></i>
                        Vitals
                        <span class="badge bg-danger ms-1">@ipd.Vitals.Count</span>
                    </h6>

                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Date &amp; Time</th>
                                    <th>Temp</th>
                                    <th>Pulse</th>
                                    <th>BP</th>
                                    <th>SpO2</th>
                                    <th>RR</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var v in ipd.Vitals)
                                {
                                    string rowClass = v.IsAbnormal ? "table-danger" : "";
                                    <tr class="@rowClass">
                                        <td class="small">
                                            @v.RecordedDateTime.ToString("dd MMM yyyy hh:mm tt")
                                        </td>
                                        <td class="small">@v.TemperatureDisplay</td>
                                        <td class="small">@v.PulseDisplay</td>
                                        <td class="small">@v.BPDisplay</td>
                                        <td class="small">@v.SpO2Display</td>
                                        <td class="small">
                                            @(v.RespirationRate.HasValue
                                                                        ? v.RespirationRate + " /min"
                                                                        : "—")
                        </td>
                        <td>
                            @if (v.IsAbnormal)
                                            {
                                                <span class="badge bg-danger">Abnormal</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Normal</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted small mt-2">
                        <i class="bx bx-info-circle me-1"></i>
                        No vitals recorded yet.
                    </p>
                }

            </div>
        </div>
    }
}
