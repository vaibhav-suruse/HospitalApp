@{
    ViewData["Title"] = "Bed Allocation";
}

<h3 class="mb-4">Bed Allocation</h3>

<form method="post" asp-action="Create">
    <input type="hidden" name="BedId" id="SelectedBedId" />
    <input type="hidden" name="IPDId" value="@Model.IPDId" />
    <div id="wardContainer"></div>

    <div class="text-center mt-4">
        <button type="submit" class="btn btn-primary px-4">
            Assign Bed
        </button>
    </div>
</form>

<style>

    .ward-container {
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        background: #f8f9fa;
        padding: 20px;
    }

    .ward-title {
        background: #f8f9fa;
        color: #7E7E82;
        padding: 10px 15px;
        border-radius: 8px;
        font-size: 14px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.08);
    }

    .room-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-top: 20px;
    }

    .room-card {
        border: 1px solid #ddd;
        padding: 15px;
        border-radius: 10px;
        width: 260px;
        background: #ffffff;
        box-shadow: 0 4px 8px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .room-card:hover {
            transform: translateY(-5px);
        }

    .room-title {
        font-weight: 600;
        margin-bottom: 15px;
        font-size: 12px;
        color: #333;
    }

    .bed-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .bed {
        width: 42px;
        height: 50px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 10px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: 0.2s;
    }

        .bed.available {
            background: #3D8753;
            color: white;
        }

            .bed.available:hover {
                transform: scale(1.1);
            }

        .bed.occupied {
            background: #dc3545;
            color: white;
            cursor: not-allowed;
        }

        .bed.maintenance {
            background: #C29813;
            color: white;
        }

        .bed.selected {
            border: 3px solid #146CC4;
            box-shadow: 0 0 10px rgba(0,123,255,0.6);
        }

</style>

@section Scripts {

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>

              let selectedBedId = null;

        $(document).ready(function () {
            loadWards();
        });

        function loadWards() {

            $("#wardContainer").html("");

            $.get("/IPDBedAllocation/GetWards", function (wards) {

                $.each(wards, function (i, ward) {

                    let wardHtml = `
                        <div class="ward-container mb-5">
                            <h2 class="ward-title">${ward.wardName}</h2>
                            <div class="room-wrapper" id="rooms-${ward.wardId}"></div>
                        </div>
                    `;

                    $("#wardContainer").append(wardHtml);

                    loadRooms(ward.wardId);
                });

            });
        }

        function loadRooms(wardId) {

            $.get("/IPDBedAllocation/GetRoomsByWard",
                { wardId: wardId },
                function (rooms) {

                    $.each(rooms, function (i, room) {

                        let roomHtml = `
                            <div class="room-card">
                                <div class="room-title">
                                    Room : ${room.roomNumber}
                                </div>
                                <div class="bed-wrapper" id="beds-${room.roomId}"></div>
                            </div>
                        `;

                        $(`#rooms-${wardId}`).append(roomHtml);

                        loadBeds(room.roomId);
                    });

                });
        }


        function loadBeds(roomId) {

            $.get("/IPDBedAllocation/GetBedsByRoom",
                { roomId: roomId },
                function (beds) {

                    if (beds.length === 0) {
                        $(`#beds-${roomId}`).html(`<div class="text-muted">No Beds Found</div>`);
                        return;
                    }

                    $.each(beds, function (i, bed) {

                                                    let bedClass = "bed";
        if (bed.operationalStatus === "Occupied") {
            bedClass += " occupied";
        } else if (bed.operationalStatus === "Maintenance") {
            bedClass += " maintenance";
        } else {
            bedClass += " available";
        }

                        let bedHtml = `
                            <div class="${bedClass}"
                                 data-bedid="${bed.bedId}">
                                 <div style="display:flex; flex-direction:column; align-items:center;">
            <i class="bx bx-bed" style="font-size:24px;"></i>
            <span>${bed.bedNumber}</span>
        </div>
                            </div>
                        `;

                        $(`#beds-${roomId}`).append(bedHtml);
                    });

                });
        }

        $(document).on("click", ".bed.available", function () {

            $(".bed").removeClass("selected");

            $(this).addClass("selected");

            selectedBedId = $(this).data("bedid");
            $("#SelectedBedId").val(selectedBedId);
        });

        $("form").submit(function (e) {

            if (!selectedBedId) {
                alert("Please select a bed.");
                e.preventDefault();
            }

        });

    </script>

}


