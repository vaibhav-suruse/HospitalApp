@model WebApplicationSampleTest2.Models.BedShiftVM
@{
    ViewData["Title"] = "Shift Bed";
}

<div class="container-fluid">
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between mb-3">
                <h4><i class="fas fa-exchange-alt me-2"></i>Shift Bed</h4>
                <a asp-controller="IPDAdmission"
                   asp-action="Details"
                   asp-route-id="@Model.IPDId"
                   class="btn btn-secondary btn-sm">Back</a>
            </div>
            <hr />

            @* PATIENT INFO *@
            <div class="alert alert-info">
                <div class="row">
                    <div class="col-md-4">
                        <strong>Patient:</strong> @Model.PatientName
                    </div>
                    <div class="col-md-4">
                        <strong>IPD No:</strong> @Model.AdmissionNumber
                    </div>
                    <div class="col-md-4">
                        <strong>Current Bed:</strong>
                        <span class="badge bg-primary">
                            @Model.CurrentWardName → @Model.CurrentRoomNumber → @Model.CurrentBedNumber
                        </span>
                    </div>
                </div>
            </div>

            <form asp-action="ShiftBed" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="IPDId" value="@Model.IPDId" />
                <input type="hidden" name="CurrentBedId" value="@Model.CurrentBedId" />
                <input type="hidden" id="NewBedId" name="NewBedId" value="0" />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label>
                            <strong>Reason for Shift</strong>
                            <small class="text-muted">(optional)</small>
                        </label>
                        <input type="text" name="Reason" class="form-control"
                               placeholder="e.g. Patient condition improved, moved to general ward" />
                    </div>
                    <div class="col-md-6 d-flex align-items-end">
                        <div class="alert alert-warning mb-0 w-100" id="selectedBedInfo">
                            <i class="fas fa-info-circle me-1"></i>
                            No bed selected yet. Click an available bed below.
                        </div>
                    </div>
                </div>

                @* BED MAP *@
                <h5 class="text-primary mb-3">
                    <i class="fas fa-map me-2"></i>Select New Bed
                </h5>

                <div class="mb-3">
                    <span class="badge me-2" style="background:#3D8753; padding:6px 10px;">
                        Available
                    </span>
                    <span class="badge me-2" style="background:#dc3545; padding:6px 10px;">
                        Occupied
                    </span>
                    <span class="badge me-2" style="background:#C29813; padding:6px 10px;">
                        Maintenance
                    </span>
                    <span class="badge me-2" style="background:#146CC4; padding:6px 10px;">
                        Current Bed
                    </span>
                </div>

                <div id="wardContainer"></div>

                <div class="d-flex justify-content-end mt-4">
                    <a asp-controller="IPDAdmission"
                       asp-action="Details"
                       asp-route-id="@Model.IPDId"
                       class="btn btn-secondary me-2">Cancel</a>
                    <button type="submit" class="btn btn-primary" id="btnShift" disabled>
                        <i class="fas fa-exchange-alt me-1"></i> Confirm Shift
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .ward-container {
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        background: #f8f9fa;
        padding: 20px;
        margin-bottom: 20px;
    }

    .ward-title {
        background: #f8f9fa;
        color: #7E7E82;
        padding: 10px 15px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: bold;
        box-shadow: 0 4px 8px rgba(0,0,0,0.08);
    }

    .room-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-top: 20px;
    }

    .room-card {
        border: 1px solid #ddd;
        padding: 15px;
        border-radius: 10px;
        width: 260px;
        background: #ffffff;
        box-shadow: 0 4px 8px rgba(0,0,0,0.08);
    }

    .room-title {
        font-weight: 600;
        margin-bottom: 15px;
        font-size: 12px;
        color: #333;
    }

    .bed-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .bed {
        width: 52px;
        height: 60px;
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 10px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: 0.2s;
    }

        .bed i {
            font-size: 20px;
        }

        .bed.available {
            background: #3D8753;
            color: white;
        }

            .bed.available:hover {
                transform: scale(1.1);
            }

        .bed.occupied {
            background: #dc3545;
            color: white;
            cursor: not-allowed;
            opacity: 0.7;
        }

        .bed.maintenance {
            background: #C29813;
            color: white;
            cursor: not-allowed;
            opacity: 0.7;
        }

        .bed.current {
            background: #146CC4;
            color: white;
            cursor: not-allowed;
        }

        .bed.selected {
            border: 3px solid #000;
            box-shadow: 0 0 12px rgba(0,0,0,0.4);
            transform: scale(1.1);
        }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        var currentBedId = @Model.CurrentBedId;
        var selectedBedId = 0;

        $(document).ready(function () {
            loadWards();
        });

        function loadWards() {
            $("#wardContainer").html('<div class="text-center p-4"><i class="fas fa-spinner fa-spin"></i> Loading beds...</div>');

            $.get("/IPDBedAllocation/GetWards", function (wards) {
                $("#wardContainer").html("");

                if (!wards || wards.length === 0) {
                    $("#wardContainer").html('<div class="alert alert-warning">No wards found.</div>');
                    return;
                }

                $.each(wards, function (i, ward) {
                    let wardHtml = `
                        <div class="ward-container">
                            <div class="ward-title">
                                <i class="fas fa-hospital me-2"></i>${ward.WardName}
                            </div>
                            <div class="room-wrapper" id="rooms-${ward.WardId}"></div>
                        </div>`;
                    $("#wardContainer").append(wardHtml);
                    loadRooms(ward.WardId);
                });
            });
        }

        function loadRooms(wardId) {
            $.get("/IPDBedAllocation/GetRoomsByWard", { wardId: wardId }, function (rooms) {
                if (!rooms || rooms.length === 0) {
                    $(`#rooms-${wardId}`).html('<div class="text-muted p-2">No rooms in this ward.</div>');
                    return;
                }

                $.each(rooms, function (i, room) {
                    let roomHtml = `
                        <div class="room-card">
                            <div class="room-title">
                                <i class="fas fa-door-open me-1"></i> Room: ${room.RoomNumber}
                            </div>
                            <div class="bed-wrapper" id="beds-${room.RoomId}"></div>
                        </div>`;
                    $(`#rooms-${wardId}`).append(roomHtml);
                    loadBeds(room.RoomId);
                });
            });
        }

        function loadBeds(roomId) {
            $.get("/IPDBedAllocation/GetBedsByRoom", { roomId: roomId }, function (beds) {
                if (!beds || beds.length === 0) {
                    $(`#beds-${roomId}`).html('<div class="text-muted" style="font-size:11px;">No beds</div>');
                    return;
                }

                $.each(beds, function (i, bed) {
                    let bedClass = "bed";
                    let clickable = false;

                    if (bed.BedId === currentBedId) {
                        bedClass += " current";
                    } else if (bed.OperationalStatus === "Occupied") {
                        bedClass += " occupied";
                    } else if (bed.OperationalStatus === "Maintenance" ||
                               bed.OperationalStatus === "Cleaning" ||
                               bed.OperationalStatus === "Blocked") {
                        bedClass += " maintenance";
                    } else {
                        bedClass += " available";
                        clickable = true;
                    }

                    let bedHtml = `
                        <div class="${bedClass}" data-bedid="${bed.BedId}"
                             data-bednumber="${bed.BedNumber}"
                             title="${bed.OperationalStatus}">
                            <i class="bx bx-bed"></i>
                            <span>${bed.BedNumber}</span>
                        </div>`;

                    $(`#beds-${roomId}`).append(bedHtml);
                });
            });
        }

        // Bed click
        $(document).on("click", ".bed.available", function () {
            $(".bed").removeClass("selected");
            $(this).addClass("selected");

            selectedBedId = $(this).data("bedid");
            var bedNumber = $(this).data("bednumber");

            $("#NewBedId").val(selectedBedId);
            $("#btnShift").prop("disabled", false);
            $("#selectedBedInfo").html(
                `<i class="fas fa-check-circle me-1 text-success"></i>
                 Selected Bed: <strong>${bedNumber}</strong> — Click "Confirm Shift" to proceed.`
            );
        });

        // Form submit validation
        $("form").submit(function (e) {
            if (selectedBedId <= 0) {
                alert("Please select a bed to shift to.");
                e.preventDefault();
            }
        });
    </script>
}