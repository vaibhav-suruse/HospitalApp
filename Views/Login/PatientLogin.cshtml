@{
    ViewData["Title"] = "Patient Login";
    Layout = "~/Views/Shared/_BlankLayout.cshtml";
}

<div class="account-pages my-5 pt-sm-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6 col-xl-5">

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success text-center mb-3">
                        @TempData["Success"]
                    </div>
                }

                <div class="card overflow-hidden">
                    <div class="bg-primary bg-soft">
                        <div class="row">
                            <div class="col-7">
                                <div class="text-primary p-4">
                                    <h5 class="text-primary">
                                        Patient Login
                                    </h5>
                                    <p>Sign in to your health portal</p>
                                </div>
                            </div>
                            <div class="col-5 align-self-end">
                                <img src="~/assets/images/profile-img.png"
                                     class="img-fluid" />
                            </div>
                        </div>
                    </div>

                    <div class="card-body pt-0">
                        <div class="p-2">

                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger">
                                    @ViewBag.Error
                                </div>
                            }

                            <form asp-action="PatientLogin"
                                  asp-controller="Login"
                                  method="post">
                                @Html.AntiForgeryToken()
                                <div class="mb-3">
                                    <label class="form-label">
                                        Email Address
                                    </label>
                                    <input type="email"
                                           name="email"
                                           class="form-control"
                                           placeholder="Enter your email"
                                           required />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">
                                        Password
                                    </label>
                                    <div class="input-group auth-pass-inputgroup">
                                        <input type="password"
                                               name="password"
                                               id="patientPassword"
                                               class="form-control"
                                               placeholder="Enter password"
                                               required />
                                        <button class="btn btn-light"
                                                type="button"
                                                id="togglePass">
                                            <i class="mdi mdi-eye-outline"
                                               id="eyeIcon"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="mt-3 d-grid">
                                    <button type="submit"
                                            class="btn btn-primary">
                                        Sign In
                                    </button>
                                </div>

                                <div class="mt-3 text-center">
                                    <a asp-action="ForgotPassword"
                                       asp-controller="Login"
                                       class="text-muted">
                                        <i class="mdi mdi-lock me-1"></i>
                                        Forgot your password?
                                    </a>
                                </div>

                                <div class="mt-3 text-center">
                                    <p>
                                        New patient?
                                        <a asp-action="PatientRegister"
                                           asp-controller="Login"
                                           class="fw-medium text-primary">
                                            Register here
                                        </a>
                                    </p>
                                </div>

                               

                            </form>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('togglePass')
            .addEventListener('click', function () {
            var field = document.getElementById('patientPassword');
            var icon  = document.getElementById('eyeIcon');
            if (field.type === 'password') {
                field.type = 'text';
                icon.classList.replace(
                    'mdi-eye-outline', 'mdi-eye-off-outline');
            } else {
                field.type = 'password';
                icon.classList.replace(
                    'mdi-eye-off-outline', 'mdi-eye-outline');
            }
        });
    </script>
}