            var dropdown = document.getElementById('symptomDropdown');
            var id = dropdown.value;
            var name = dropdown.options[dropdown.selectedIndex].getAttribute('data-name');

            if (!id) {
                alert('Please select a symptom.');
                return;
            }

            // Duplicate check
            if (addedSymptoms.includes(id)) {
                alert('Symptom already added.');
                return;
            }

            addedSymptoms.push(id);
            symptomCount++;

            // Remove empty row
            var noRow = document.getElementById('noSymptomsRow');
            if (noRow) noRow.remove();

            // Add table row
            var tbody = document.getElementById('symptomsBody');
            var row = `<tr id="symRow_${id}">
                            <td>${symptomCount}</td>
                            <td>${name}</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-danger"
                                    onclick="removeSymptom('${id}', 'symRow_${id}', 'symInput_${id}')">
                                    Remove
                                </button>
                            </td>
                       </tr>`;
            tbody.innerHTML += row;

            // Add hidden input
            var hiddenDiv = document.getElementById('symptomHiddenInputs');
            hiddenDiv.innerHTML += `<input type="hidden" id="symInput_${id}" name="SymptomIds" value="${id}" />`;

            // Reset dropdown
            dropdown.value = '';
        }

        function removeSymptom(id, rowId, inputId) {
            document.getElementById(rowId).remove();
            document.getElementById(inputId).remove();
            addedSymptoms = addedSymptoms.filter(x => x !== id);
        }

        // ===============================
        // PRESCRIPTION
        // ===============================
        let prescCount = 0;
        let addedMedicines = [];

        function addPrescription() {
            var dropdown = document.getElementById('medicineDropdown');
            var id = dropdown.value;
            var name = dropdown.options[dropdown.selectedIndex].text;
            var morning = document.getElementById('pMorning').checked;
            var afternoon = document.getElementById('pAfternoon').checked;
            var evening = document.getElementById('pEvening').checked;
            var days = document.getElementById('pDays').value;
            var route = document.getElementById('pRoute').value;
            var dosage = document.getElementById('pDosage').value;

            if (!id) { alert('Please select a medicine.'); return; }
            if (!morning && !afternoon && !evening) { alert('Please select at least one time (M/A/E).'); return; }
            if (!days) { alert('Please enter number of days.'); return; }
            if (addedMedicines.includes(id)) { alert('Medicine already added.'); return; }

            addedMedicines.push(id);
            prescCount++;

            var noRow = document.getElementById('noPrescRow');
            if (noRow) noRow.remove();

            var tbody = document.getElementById('prescriptionBody');
            var row = `<tr id="prescRow_${id}">
                        <td>${prescCount}</td>
                        <td>${name}</td>
                        <td>${morning ? '✓' : '-'}</td>
                        <td>${afternoon ? '✓' : '-'}</td>
                        <td>${evening ? '✓' : '-'}</td>
                        <td>${days}</td>
                        <td>${route}</td>
                        <td>${dosage || '-'}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-danger"
                                onclick="removePrescription('${id}', 'prescRow_${id}')">
                                Remove
                            </button>
                        </td>
                       </tr>`;
            tbody.innerHTML += row;

            // Hidden inputs — array indexed for model binding
            var idx = prescCount - 1;
            var hiddenDiv = document.getElementById('prescriptionHiddenInputs');
            hiddenDiv.innerHTML += `
                <input type="hidden" name="Prescriptions[${idx}].MedicineId" value="${id}" />
                <input type="hidden" name="Prescriptions[${idx}].Morning" value="${morning}" />
                <input type="hidden" name="Prescriptions[${idx}].Afternoon" value="${afternoon}" />
                <input type="hidden" name="Prescriptions[${idx}].Evening" value="${evening}" />
                <input type="hidden" name="Prescriptions[${idx}].Days" value="${days}" />
                <input type="hidden" name="Prescriptions[${idx}].Route" value="${route}" />
                <input type="hidden" name="Prescriptions[${idx}].Dosage" value="${dosage}" />
            `;

            // Reset fields
            dropdown.value = '';
            document.getElementById('pMorning').checked = false;
            document.getElementById('pAfternoon').checked = false;
            document.getElementById('pEvening').checked = false;
            document.getElementById('pDays').value = '';
            document.getElementById('pDosage').value = '';
        }

        function removePrescription(id, rowId) {
            document.getElementById(rowId).remove();
            addedMedicines = addedMedicines.filter(x => x !== id);
        }

        // ===============================
        // INVESTIGATION
        // ===============================
        let invCount = 0;

        function addInvestigation() {
            var type = document.getElementById('invType').value;
            var testName = document.getElementById('invTestName').value.trim();
            var priority = document.getElementById('invPriority').value;
            var instructions = document.getElementById('invInstructions').value.trim();

            if (!type) { alert('Please select investigation type.'); return; }
            if (!testName) { alert('Please enter test name.'); return; }

            invCount++;

            var noRow = document.getElementById('noInvRow');
            if (noRow) noRow.remove();

            var tbody = document.getElementById('investigationBody');
            var row = `<tr id="invRow_${invCount}">
                        <td>${invCount}</td>
                        <td>${type}</td>
                        <td>${testName}</td>
                        <td>${priority}</td>
                        <td>${instructions || '-'}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-danger"
                                onclick="removeInvestigation('invRow_${invCount}', 'invHidden_${invCount}')">
                                Remove
                            </button>
                        </td>
                       </tr>`;
            tbody.innerHTML += row;

            var idx = invCount - 1;
            var hiddenDiv = document.getElementById('investigationHiddenInputs');
            hiddenDiv.innerHTML += `
                <div id="invHidden_${invCount}">
                    <input type="hidden" name="Investigations[${idx}].InvestigationType" value="${type}" />
                    <input type="hidden" name="Investigations[${idx}].TestName" value="${testName}" />
                    <input type="hidden" name="Investigations[${idx}].Priority" value="${priority}" />
                    <input type="hidden" name="Investigations[${idx}].Instructions" value="${instructions}" />
                </div>
            `;

            // Reset
            document.getElementById('invTestName').value = '';
            document.getElementById('invInstructions').value = '';
        }

        function removeInvestigation(rowId, hiddenId) {
            document.getElementById(rowId).remove();
            document.getElementById(hiddenId).remove();
        }

    </script>
}
