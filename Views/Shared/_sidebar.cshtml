@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var role = HttpContextAccessor.HttpContext.Session.GetString("UserRole") ?? "User";
}

<!-- ========== Left Sidebar Start ========== -->
<div class="vertical-menu">
    <div data-simplebar class="h-100">
        <div id="sidebar-menu">
            <ul class="metismenu list-unstyled" id="side-menu" style="width:103%">

                <li class="menu-title" key="t-menu">Menu</li>

                <!-- DASHBOARD -->
                @if (role == "SuperAdmin")
                {
                    <li>
                        <a asp-action="Dash" asp-controller="DashBord">
                            <i class="bx bx-home-circle"></i>
                            <span key="t-dashboards">Dashboard</span>
                        </a>
                    </li>
                }
                @if (role != "SuperAdmin")
                {
                    <li>
                        <a asp-action="Index" asp-controller="DashBord">
                            <i class="bx bx-home-circle"></i>
                            <span key="t-dashboards">Dashboard</span>
                        </a>
                    </li>
                }

                <!-- ══════════════════════════════════════
                     OPD — with live pending badge
                ══════════════════════════════════════ -->
                @if (role != "SuperAdmin")
                {
                   
                }

                <!-- CONFIGURATION -->
                <li>
                    <a href="javascript: void(0);" class="has-arrow waves-effect">
                        <i class="bx bx-cog"></i>
                        <span key="t-layouts">Configuration</span>
                    </a>
                    <ul class="sub-menu" aria-expanded="true">
                        @if (role != "SuperAdmin")
                        {
                            <li><a asp-action="Index" asp-controller="OPDAppointment" key="t-light-sidebar">Appointment</a></li>
                            <li><a asp-action="Index" asp-controller="Symptom" key="t-light-sidebar">Symptom</a></li>
                            <li><a asp-action="Index" asp-controller="Medicine" key="t-light-sidebar">Medicine</a></li>
                            <li><a asp-action="PatientList" asp-controller="Patient" key="t-light-sidebar">Patient List</a></li>
                            <li><a asp-action="Index" asp-controller="BillingMaster" key="t-light-sidebar">Billing</a></li>
                            <li><a asp-action="Index" asp-controller="Doctor" key="t-light-sidebar">Doctor</a></li>
                            <li><a asp-action="Index" asp-controller="ReferenceDoctor" key="t-light-sidebar">Reference Doctor</a></li>
                            <li><a asp-action="Index" asp-controller="Nurse" key="t-light-sidebar">Nurse</a></li>
                            <li><a asp-action="Index" asp-controller="NursingChargesMaster" key="t-light-sidebar">Nurse Charges</a></li>
                            <li><a asp-action="Index" asp-controller="OperationMaster" key="t-light-sidebar">Operations</a></li>
                        }
                        @if (role == "SuperAdmin")
                        {
                            <li><a asp-action="Index" asp-controller="Hospital" key="t-light-sidebar">Hospital</a></li>
                            <li><a asp-action="Index" asp-controller="User" key="t-light-sidebar">User</a></li>
                        }
                    </ul>
                </li>

                <!-- IPD -->
                <li>
                    <a href="javascript: void(0);" class="has-arrow waves-effect">
                        <i class="bx bx-bed"></i>
                        <span key="t-layouts">IPD</span>
                    </a>
                    <ul class="sub-menu" aria-expanded="true">
                        @if (role != "SuperAdmin")
                        {
                            <li><a asp-action="Index" asp-controller="IPDDashboard" key="t-light-sidebar">IPD Dashboard</a></li>
                            <li><a asp-action="Index" asp-controller="Ward" key="t-light-sidebar">Ward</a></li>
                            <li><a asp-action="Index" asp-controller="Room" key="t-light-sidebar">Room</a></li>
                            <li><a asp-action="Index" asp-controller="Bed" key="t-light-sidebar">Bed</a></li>
                            <li><a asp-action="Index" asp-controller="IPDAdmission" key="t-light-sidebar">IPD List</a></li>
                        }
                    </ul>
                </li>

                <!-- MEDICAL / INVENTORY -->
                <li>
                    <a href="javascript: void(0);" class="has-arrow waves-effect">
                        <i class="bx bx-box"></i>

                        <span key="t-layouts">Medical</span>
                    </a>
                    <ul class="sub-menu" aria-expanded="true">
                        @if (role != "SuperAdmin")
                        {
                            <li><a asp-action="Index" asp-controller="PharmacyDashboard">Pharmacy Dashboard</a></li>
                            <li>
                                <a asp-action="Index" asp-controller="PharmacyQueue" class="waves-effect">
                                    <i class="bx bx-user-check"></i>
                                    <span>OPD Queue</span>
                                    <span class="badge badge-pill badge-soft-danger float-end"
                                          id="sidebar-opd-badge"
                                          style="display:none;
                                                 background:#fff1f0;
                                                 color:#e74c3c;
                                                 font-size:.68rem;
                                                 font-weight:700;
                                                 padding:3px 8px;
                                                 border-radius:99px;
                                                 min-width:20px;
                                                 text-align:center;">
                                        0
                                    </span>
                                </a>
                            </li>
                             <li>
                                <a asp-action="Index" asp-controller="IPDPharmacyQueue" class="waves-effect">
                                    <i class="bx bx-user-check"></i>
                                    <span>IPD Queue</span>
                                    <span class="badge badge-pill badge-soft-danger float-end"
                                          id="sidebar-opd-badge"
                                          style="display:none;
                                                 background:#fff1f0;
                                                 color:#e74c3c;
                                                 font-size:.68rem;
                                                 font-weight:700;
                                                 padding:3px 8px;
                                                 border-radius:99px;
                                                 min-width:20px;
                                                 text-align:center;">
                                        0
                                    </span>
                                </a>
                            </li>
                             
                            <li><a asp-action="Index" asp-controller="Counter" key="t-light-sidebar">Pharmacy Counter</a></li>
                            <li><a asp-action="Index" asp-controller="Inventory" key="t-light-sidebar">Inventory</a></li>
                            <li><a asp-action="Index" asp-controller="Supplier" key="t-light-sidebar">Supplier Master</a></li>
                            <li><a asp-action="Index" asp-controller="Category" key="t-light-sidebar">Category Master</a></li>
                        }
                    </ul>
                </li>

                <!-- LAB -->
                @if (role == "LabStaff" || role == "Admin")
                {
                    <li>
                        <a asp-action="Index" asp-controller="LabInvestigation">
                            <i class="bx bx-test-tube"></i>
                            <span>Lab Investigations</span>
                        </a>
                    </li>
                }

                <!-- LOGOUT -->
                <li>
                    <a asp-action="Login" asp-controller="User">
                        <i class="bx bx-log-out"></i>
                        <span key="t-authentication">Log Out</span>
                    </a>
                </li>

            </ul>
        </div>
    </div>
</div>
<!-- Left Sidebar End -->
<!-- ══════════════════════════════════════════════════
     SIDEBAR OPD BADGE — polls pending count every 8s
══════════════════════════════════════════════════ -->
<script>
    (function () {
        function pollOPDBadge() {
            $.ajax({
                url:  '/Notification/GetPendingCount',
                type: 'GET',
                success: function (res) {
                    var count  = res.count || 0;
                    var badge  = document.getElementById('sidebar-opd-badge');
                    if (!badge) return;
                    if (count > 0) {
                        badge.textContent = count > 99 ? '99+' : count;
                        badge.style.display = 'inline-block';
                    } else {
                        badge.style.display = 'none';
                    }
                }
            });
        }
        // Run immediately + every 8s
        $(document).ready(function () {
            pollOPDBadge();
            setInterval(pollOPDBadge, 8000);
        });
    })();
</script>



















