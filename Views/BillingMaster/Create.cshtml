@using WebApplicationSampleTest2.Models
@model BillingMaster

@{
    ViewData["Title"] = Model.isUpdate ? "Edit Billing" : "Create Billing";
}

<h4 class="card-title">
    @(Model.isUpdate ? "Edit Billing" : "Create Billing")
</h4>

<div class="row">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body">

                <form id="billingForm"
                      asp-action="Create"
                      asp-controller="BillingMaster"
                      method="post"
                      novalidate>

                    @Html.HiddenFor(x => x.Id)
                    @Html.HiddenFor(x => x.isUpdate)

                    <!-- Row 1 -->
                    <div class="row">
                        <!-- Billing Name -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Billing Name</label>
                                <input asp-for="Name"
                                       id="BillingName"
                                       class="form-control"
                                       placeholder="Enter Billing Name" />
                                <small class="text-danger" id="errBillingName"></small>
                            </div>
                        </div>

                        <!-- Billing Type -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Billing Type</label>
                                <input asp-for="BillingType"
                                       id="BillingType"
                                       class="form-control"
                                       placeholder="Enter Billing Type" />
                                <small class="text-danger" id="errBillingType"></small>
                            </div>
                        </div>
                    </div>

                    <!-- Row 2 -->
                    <div class="row">
                        <!-- LEFT -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Amount</label>
                                <input asp-for="Amount"
                                       id="Amount"
                                       type="number"
                                       step="0.01"
                                       class="form-control" />
                                <small class="text-danger" id="errAmount"></small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Hospital Status</label>
                                <select asp-for="IsActive"
                                        id="IsActive"
                                        class="form-select">
                                    <option value="1">Active</option>
                                    <option value="0">Inactive</option>
                                </select>
                            </div>
                        </div>

                        <!-- RIGHT -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea asp-for="Description"
                                          id="Description"
                                          class="form-control"
                                          rows="5"></textarea>
                                <small class="text-danger" id="errDescription"></small>
                            </div>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div>
                        <button type="submit" class="btn btn-primary">
                            @(Model.isUpdate ? "Update" : "Submit")
                        </button>

                        <a asp-action="Index"
                           asp-controller="BillingMaster"
                           class="btn btn-secondary">
                            Cancel
                        </a>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/libs/jquery/jquery.min.js"></script>

    <script>
        function clearErrors() {
            $(".text-danger").text("");
            $(".form-control, .form-select").removeClass("is-invalid");
        }

        function setError(inputId, errorId, message) {
            if (inputId !== "") {
                $("#" + inputId).addClass("is-invalid");
            }
            $("#" + errorId).text(message);
        }

        // 🔥 Remove leading zeros while typing
        $("#Amount").on("input", function () {
            let value = $(this).val();

            if (value.length > 1 && value.startsWith("0") && !value.startsWith("0.")) {
                value = value.replace(/^0+/, '');
                $(this).val(value);
            }
        });

        $("#billingForm").on("submit", function (e) {

            clearErrors();
            let isValid = true;

            // Billing Name
            if ($("#BillingName").val().trim() === "") {
                setError("BillingName", "errBillingName", "Billing Name is required");
                isValid = false;
            }

            // Billing Type
            if ($("#BillingType").val().trim() === "") {
                setError("BillingType", "errBillingType", "Please select billing type");
                isValid = false;
            }

            // 🔥 Amount validation (NO leading zero)
            let amtVal = $("#Amount").val().trim();

            if (/^0[0-9]+/.test(amtVal)) {
                setError("Amount", "errAmount", "Amount should not start with 0");
                isValid = false;
            }
            else {
                let amt = parseFloat(amtVal);
                if (isNaN(amt) || amt <= 0) {
                    setError("Amount", "errAmount", "Amount must be greater than 0");
                    isValid = false;
                }
            }

            // Description
            if ($("#Description").val().trim() === "") {
                setError("Description", "errDescription", "Description is required");
                isValid = false;
            }

            if (!isValid) {
                e.preventDefault();
            }
        });
    </script>
}