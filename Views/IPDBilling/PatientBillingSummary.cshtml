@model WebApplicationSampleTest2.Models.BillingSummaryVM
@{
    ViewData["Title"] = "Patient Billing Summary";
}

<div class="container-fluid">

    @* ── TOP BAR ── *@
    <div class="d-flex justify-content-between mb-3">
        <h4>
            <i class="fas fa-file-invoice-dollar me-2"></i>
            Patient Billing Summary
        </h4>
        <div>
            @if (Model.BillId.HasValue)
            {
                <a asp-action="PrintBill"
                   asp-route-ipdId="@Model.IPDId"
                   target="_blank"
                   class="btn btn-primary btn-sm me-1">
                    🖨 Print Bill
                </a>
                @* <a asp-action="GenerateBill"
                   asp-route-ipdId="@Model.IPDId"
                   class="btn btn-primary btn-sm me-1">
                    💳 Manage Bill
                </a> *@
            }
            else
            {
                <a asp-action="GenerateBill"
                   asp-route-ipdId="@Model.IPDId"
                   class="btn btn-primary btn-sm me-1">
                    ➕ Generate Bill
                </a>
            }
            <a asp-controller="IPDAdmission"
               asp-action="Details"
               asp-route-id="@Model.IPDId"
               class="btn btn-secondary btn-sm">
                ← Back
            </a>
        </div>
    </div>

    @* ── PATIENT INFO CARD ── *@
    <div class="row g-3 mb-3">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-primary text-white py-2">
                    <i class="fas fa-user me-1"></i>
                    Patient Information
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <small class="text-muted">Patient Name</small>
                            <div class="fw-bold fs-5">
                                @Model.PatientName
                            </div>
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">Age / Gender</small>
                            <div class="fw-bold">
                                @(Model.Age.HasValue
                                                                ? Model.Age + " Yrs"
                                                                : "-")
                                / @(Model.Gender ?? "-")
                            </div>
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">Phone</small>
                            <div class="fw-bold">
                                @(Model.PhoneNumber ?? "-")
                            </div>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted">Address</small>
                            <div>@(Model.Address ?? "-")</div>
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">Doctor</small>
                            <div>Dr. @(Model.DoctorName ?? "-")</div>
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">
                                Ward / Bed
                            </small>
                            <div>
                                @(Model.WardName ?? "-")
                                /
                                @(Model.BedNumber ?? "-")
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-primary text-white py-2">
                    <i class="fas fa-hospital me-1"></i>
                    Admission Details
                </div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <tr>
                            <td class="text-muted">IPD No</td>
                            <td>
                                <strong>@Model.AdmissionNumber</strong>
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">Admitted</td>
                            <td>
                                @Model.AdmissionDateTime
                               
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">Discharged</td>
                            <td>
                                @(Model.DischargeDateTime.HasValue
                                                                ? Model.DischargeDateTime.Value
                                                                .ToString("dd-MM-yyyy HH:mm")
                                                                : "-")
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">Total Days</td>
                            <td>
                                <span class="badge bg-primary">
                                    @Model.TotalDays days
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">Status</td>
                            <td>
                                @if (Model.AdmissionStatus == "Admitted")
                                {
                                    <span class="badge bg-success">
                                        🟢 Admitted
                                    </span>
                                }
                                else if (Model.AdmissionStatus
                                == "Discharged")
                                {
                                    <span class="badge bg-secondary">
                                        ✅ Discharged
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning
                                                     text-dark">
                                        @Model.AdmissionStatus
                                    </span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @* ── BILL STATUS BANNER ── *@
    @if (Model.BillId.HasValue)
    {
        var statusColor = Model.PaymentStatus == "Paid"
        ? "success"
        : Model.PaymentStatus == "Partial"
        ? "warning"
        : "danger";

        <div class="alert alert-@statusColor mb-3 py-2">
            <div class="row align-items-center">
                <div class="col-md-2">
                    <small>Bill No</small>
                    <div class="fw-bold">@Model.BillNumber</div>
                </div>
                <div class="col-md-2">
                    <small>Bill Date</small>
                    <div>
                        @Model.BillDate?.ToString("dd-MM-yyyy")
                    </div>
                </div>
                <div class="col-md-2 text-center">
                    <small>Total Amount</small>
                    <div class="fw-bold fs-5">
                        ₹@Model.TotalAmount.ToString("0.00")
                    </div>
                </div>
                <div class="col-md-2 text-center">
                    <small>Paid</small>
                    <div class="fw-bold text-success fs-5">
                        ₹@Model.PaidAmount.ToString("0.00")
                    </div>
                </div>
                <div class="col-md-2 text-center">
                    <small>Due</small>
                    <div class="fw-bold text-danger fs-5">
                        ₹@Model.DueAmount.ToString("0.00")
                    </div>
                </div>
                <div class="col-md-2 text-center">
                    <small>Status</small>
                    <div>
                        <span class="badge bg-@statusColor
                                @(statusColor == "warning"
                                                              ? "text-dark" : "")
                            fs-6">
                        @Model.PaymentStatus
                    </span>
                </div>
            </div>
        </div>
    </div>
        }
    else
    {
        <div class="alert alert-warning mb-3">
            <i class="fas fa-exclamation-triangle me-2"></i>
            Bill not generated yet for this patient.
            <a asp-action="GenerateBill"
               asp-route-ipdId="@Model.IPDId"
               class="btn btn-warning btn-sm ms-2">
                Generate Bill Now
            </a>
        </div>
    }

    <div class="row g-3">

        @* ── LEFT — CHARGE BREAKDOWN ── *@
        <div class="col-md-7">

            @* CHARGE BREAKDOWN CARD *@
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-primary text-white">
                    <i class="fas fa-receipt me-1"></i>
                    Charge Breakdown
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Category</th>
                                <th class="text-end">Amount</th>
                                <th style="width:180px;">Progress</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var charges = new[]
                                {
                                                        new {
                                                        Icon  = "🛏",
                                                        Label = "Bed Charges",
                                                        Amt   = Model.BedCharges,
                                                        Color = "primary"
                                                        },
                                                        new {
                                                        Icon  = "👨‍⚕️",
                                                        Label = "Doctor Visits",
                                                        Amt   = Model.DoctorCharges,
                                                        Color = "info"
                                                        },
                                                        new {
                                                        Icon  = "💊",
                                                        Label = "Medicines",
                                                        Amt   = Model.MedicineCharges,
                                                        Color = "success"
                                                        },
                                                        new {
                                                        Icon  = "🔬",
                                                        Label = "Investigations",
                                                        Amt   = Model.InvestigationCharges,
                                                        Color = "warning"
                                                        },
                                                        new {
                                                        Icon  = "📋",
                                                        Label = "Discharge Medicines",
                                                        Amt   = Model.DischargeMedCharges,
                                                        Color = "secondary"
                                                        },
                                                        new {
                                                        Icon  = "🩺",
                                                        Label = "Nursing Charges",
                                                        Amt   = Model.NursingCharges,
                                                        Color = "warning"
                                                        },
                                                        new {
                                                        Icon  = "🏥",
                                                        Label = "Operations / OT",
                                                        Amt   = Model.OperationCharges,
                                                        Color = "danger"
                                                        },
                                                        new {
                                                        Icon  = "➕",
                                                        Label = "Other Charges",
                                                        Amt   = Model.OtherCharges,
                                                        Color = "dark"
                                                        }
                                                        };
                            }

                            @foreach (var c in charges)
                            {
                                var pct = Model.SubTotal > 0
                                ? (double)(c.Amt / Model.SubTotal * 100)
                                : 0;
                                <tr>
                                    <td>
                                        @c.Icon @c.Label
                                    </td>
                                    <td class="text-end fw-bold">
                                        @if (c.Amt > 0)
                                        {
                                            <span>
                                                ₹@c.Amt.ToString("0.00")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (c.Amt > 0)
                                        {
                                            <div class="progress"
                                                 style="height:8px;">
                                                <div class="progress-bar
                                                            bg-@c.Color"
                                                     style="width:
                                                                @pct.ToString("0")%">
                                                </div>
                                            </div>
                                            <small class="text-muted">
                                                @pct.ToString("0.0")%
                                            </small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-light">
                                <td class="fw-bold">Sub Total</td>
                                <td class="text-end fw-bold">
                                    ₹@Model.SubTotal.ToString("0.00")
                                </td>
                                <td></td>
                            </tr>
                            @if (Model.DiscountAmount > 0)
                            {
                                <tr class="text-danger">
                                    <td>
                                        Discount
                                        (@Model.DiscountPercent
                                       )
                                    </td>
                                    <td class="text-end">
                                        -₹@Model.DiscountAmount
                                       )
                                    </td>
                                    <td></td>
                                </tr>
                            }
                            <tr class="table-primary">
                                <td class="fw-bold fs-5">
                                    TOTAL
                                </td>
                                <td class="text-end fw-bold fs-5">
                                    ₹@Model.TotalAmount.ToString("0.00")
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            @* NURSING DETAIL *@
            @if (Model.NursingDetails != null
                        && Model.NursingDetails.Any())
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-primary py-2">
                        <i class="fas fa-user-nurse me-1"></i>
                        Nursing Procedures Detail
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Procedure</th>
                                    <th>Type</th>
                                    <th>Nurse</th>
                                    <th>Qty</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var n in Model.NursingDetails)
                                {
                                    <tr>
                                        <td>
                                            @n.ChargeDate
                                          
                                        </td>
                                        <td>
                                            <strong>@n.ChargeName</strong>
                                        </td>
                                        <td>
                                            <span class="badge
                                                        @(n.ChargeType == "PerDay"
                                                                                                      ? "bg-info"
                                                                                                      : "bg-secondary")">
                                        @n.ChargeType
                                    </span>
                                </td>
                                <td>@(n.NurseName ?? "-")</td>
                                <td>@n.Quantity</td>
                                <td class="text-end fw-bold">
                                    ₹@n.TotalCharge.ToString("0.00")
                                </td>
                            </tr>
                                                        }
                            </tbody>
                            @* <tfoot>
                                <tr class="table-warning">
                                    <td colspan="5" class="text-end fw-bold">
                                        Nursing Total:
                                    </td>
                                    <td class="text-end fw-bold">
                                        ₹@Model.NursingDetails
                                        .Sum(n => n.TotalCharge)
                                        .ToString("0.00")
                                    </td>
                                </tr>
                            </tfoot> *@
                        </table>
                    </div>
                </div>
            }

            @* OPERATION DETAIL *@
            @if (Model.OperationDetails != null
                        && Model.OperationDetails.Any())
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-primary text-white py-2">
                        <i class="fas fa-procedures me-1"></i>
                        Operation / OT Detail
                    </div>
                    <div class="card-body">
                        @{
                            int opIdx = 1;
                        }
                        @foreach (var op in Model.OperationDetails)
                        {
                            <div class="border rounded p-2 mb-2">
                                <div class="d-flex
                                                    justify-content-between
                                                    mb-2">
                                    <strong>
                                        @opIdx. @op.OperationName
                                    </strong>
                                    <small class="text-muted">
                                        @op.OperationDate
                                       
                                    </small>
                                </div>
                                <div class="row g-2 text-center">
                                    <div class="col-3">
                                        <div class="border rounded py-1">
                                            <div class="text-muted"
                                                 style="font-size:10px;">
                                                OT Charge
                                            </div>
                                            <div class="fw-bold">
                                                ₹@op.OTCharge.ToString("0")
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-3">
                                        <div class="border rounded py-1">
                                            <div class="text-muted"
                                                 style="font-size:10px;">
                                                Surgeon
                                            </div>
                                            <div class="fw-bold">
                                                ₹@op.SurgeonCharge
                                               
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-3">
                                        <div class="border rounded py-1">
                                            <div class="text-muted"
                                                 style="font-size:10px;">
                                                Anesthesia
                                            </div>
                                            <div class="fw-bold">
                                                ₹@op.AnesthesiaCharge
                                                
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-3">
                                        <div class="border rounded py-1">
                                            <div class="text-muted"
                                                 style="font-size:10px;">
                                                Staff
                                            </div>
                                            <div class="fw-bold">
                                                ₹@op.TotalStaffCharge
                                               
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @if (op.Staff != null && op.Staff.Any())
                                {
                                    <div class="mt-2">
                                        @foreach (var s in op.Staff)
                                        {
                                            <span class="badge
                                                                         bg-secondary
                                                                         me-1">
                                                @s.StaffType:
                                                @s.StaffName
                                                (₹@s.Charge.ToString("0"))
                                            </span>
                                        }
                                    </div>
                                }

                                <div class="text-end mt-1">
                                    <strong class="text-danger">
                                        Total:
                                        ₹@op.GrandTotal.ToString("0.00")
                                    </strong>
                                </div>
                            </div>
                            opIdx++;
                        }
                    </div>
                </div>
            }

        </div>

        @* ── RIGHT — PAYMENT SUMMARY ── *@
        <div class="col-md-5">

            @* PAYMENT VISUAL CARD *@
            @if (Model.BillId.HasValue)
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-primary text-white">
                        <i class="fas fa-money-bill-wave me-1"></i>
                        Payment Summary
                    </div>
                    <div class="card-body">

                        @* Progress bar *@
                        @{
                            var paidPct = Model.TotalAmount > 0
                            ? (double)(Model.PaidAmount
                            / Model.TotalAmount * 100)
                            : 0;
                        }
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <small class="text-muted">
                                    Payment Progress
                                </small>
                                <small class="fw-bold">
                                    @paidPct.ToString("0.0")% Paid
                                </small>
                            </div>
                            <div class="progress" style="height:20px;">
                                <div class="progress-bar bg-success"
                                     style="width:@paidPct
                                                    .ToString(" 0")%">
                                    @if (paidPct > 10)
                                    {
                                        <span>
                                            ₹@Model.PaidAmount
                                            .ToString("0")
                                        </span>
                                    }
                                </div>
                                @if (paidPct < 100)
                                {
                                    <div class="progress-bar bg-danger"
                                         style="width:@(100 - paidPct)
                                                           
                                         opacity:0.4;">
                                    </div>
                                }
                            </div>
                            <div class="d-flex
                                            justify-content-between mt-1">
                                <small class="text-success">
                                    Paid:
                                    ₹@Model.PaidAmount.ToString("0.00")
                                </small>
                                <small class="text-danger">
                                    Due:
                                    ₹@Model.DueAmount.ToString("0.00")
                                </small>
                            </div>
                        </div>

                        @* Payment History *@
                        @if (Model.Payments != null
                                            && Model.Payments.Any())
                        {
                            <h6 class="mb-2">
                                <i class="fas fa-history me-1"></i>
                                Payment History
                            </h6>
                            <table class="table table-sm
                                                  table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Mode</th>
                                        <th>Ref</th>
                                        <th class="text-end">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in Model.Payments)
                                    {
                                        <tr>
                                            <td>
                                                @p.PaymentDate
                                                
                                            </td>
                                            <td>
                                                <span class="badge bg-primary">
                                                    @p.PaymentMode
                                                </span>
                                            </td>
                                            <td>
                                                <small>
                                                    @(p.TransactionRef ?? "-")
                                                </small>
                                            </td>
                                            <td class="text-end fw-bold
                                                                    text-success">
                                                ₹@p.Amount.ToString("0.00")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="table-success">
                                        <td colspan="3"
                                            class="text-end fw-bold">
                                            Total Paid:
                                        </td>
                                        <td class="text-end fw-bold">
                                            ₹@Model.PaidAmount
                                            
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        }
                        else
                        {
                            <div class="text-muted text-center py-3">
                                No payments received yet
                            </div>
                        }
                    </div>
                </div>
            }

            
    </div>
</div>
</div>