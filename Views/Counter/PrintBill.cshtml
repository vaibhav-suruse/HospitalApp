@model CounterBillModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Bill Receipt</title>
    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: #f5f5f5;
            padding: 20px;
        }

        .receipt {
            max-width: 400px;
            margin: 0 auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        .header {
            text-align: center;
            border-bottom: 1px dashed #ddd;
            padding-bottom: 10px;
            margin-bottom: 15px;
        }

            .header h3 {
                margin: 0;
            }

            .header small {
                color: #666;
            }

        .bill-details {
            margin-bottom: 15px;
        }

            .bill-details p {
                margin: 3px 0;
                font-size: 13px;
            }

        table {
            width: 100%;
            font-size: 12px;
        }

        th, td {
            padding: 5px 0;
        }

        .total-row {
            border-top: 1px solid #ddd;
            font-weight: bold;
        }

        .footer {
            text-align: center;
            margin-top: 20px;
            padding-top: 10px;
            border-top: 1px dashed #ddd;
            font-size: 11px;
            color: #666;
        }

   
        @@media print {
            body

        {
            background: white;
            padding: 0;
        }

        .no-print {
            display: none;
        }

        }
    </style>
</head>
<body>
    <div class="receipt">
        <div class="header">
            <h3>@Model.HospitalName</h3>
            <small>@Model.HospitalAddress</small><br />
            <small>Ph: @Model.HospitalPhone | Email: @Model.HospitalEmail</small>
        </div>

        <div class="bill-details">
            <p><strong>Bill No:</strong> @Model.BillNumber</p>
            <p><strong>Date:</strong> @Model.BillDate.ToString("dd/MM/yyyy hh:mm tt")</p>
            <p><strong>Customer:</strong> @Model.CustomerName</p>
            <p><strong>Mobile:</strong> @Model.MobileNumber</p>
        </div>

        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Qty</th>
                    <th>Price</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.MedicineName</td>
                        <td>@item.Quantity</td>
                        <td>₹@item.UnitPrice.ToString("0.00")</td>
                        <td>₹@item.TotalPrice.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" class="text-end"><strong>Sub Total:</strong></td>
                    <td><strong>₹@Model.SubTotal.ToString("0.00")</strong></td>
                </tr>
                @if (Model.DiscountAmount > 0)
                {
                    <tr>
                        <td colspan="3" class="text-end">Discount (@Model.DiscountType@(Model.DiscountType == "Percentage" ? $"{Model.DiscountValue}%" : "")):</td>
                        <td>-₹@Model.DiscountAmount.ToString("0.00")</td>
                    </tr>
                }
                <tr class="total-row">
                    <td colspan="3" class="text-end"><strong>Total:</strong></td>
                    <td><strong>₹@Model.TotalAmount.ToString("0.00")</strong></td>
                </tr>
                <tr>
                    <td colspan="3" class="text-end">Payment Mode:</td>
                    <td>@Model.PaymentMode</td>
                </tr>
                <tr>
                    <td colspan="3" class="text-end">Paid:</td>
                    <td>₹@Model.PaidAmount.ToString("0.00")</td>
                </tr>
                @if (Model.DueAmount > 0)
                {
                    <tr>
                        <td colspan="3" class="text-end text-danger"><strong>Due:</strong></td>
                        <td class="text-danger"><strong>₹@Model.DueAmount.ToString("0.00")</strong></td>
                    </tr>
                }
            </tfoot>
        </table>

        <div class="footer">
            <p>Thank you for your purchase!</p>
            <p>Powered by Hospital Management System</p>
            <button class="btn btn-sm btn-primary no-print mt-2" onclick="window.print()">Print Receipt</button>
            <button class="btn btn-sm btn-secondary no-print mt-2" onclick="window.close()">Close</button>
        </div>
    </div>
</body>
</html>