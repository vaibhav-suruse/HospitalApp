@using WebApplicationSampleTest2.Models
@{
    ViewData["Title"] = "Pharmacy Counter";
    var summary = ViewBag.TodaySummary as CounterTodaySummaryModel;
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Pharmacy Counter</h4>


                <!-- Today Summary -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card bg-light">
                            <div class="card-body text-center">
                                <h6 class="text-muted">Today's Bills</h6>
                                <h3 class="mb-0">@(summary?.TotalBills ?? 0)</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-light">
                            <div class="card-body text-center">
                                <h6 class="text-muted">Total Sales</h6>
                                <h3 class="mb-0 text-primary">₹@((summary?.TotalSales ?? 0).ToString("N0"))</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-light">
                            <div class="card-body text-center">
                                <h6 class="text-muted">Collected</h6>
                                <h3 class="mb-0 text-success">₹@((summary?.TotalCollected ?? 0).ToString("N0"))</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card bg-light">
                            <div class="card-body text-center">
                                <h6 class="text-muted">Pending</h6>
                                <h3 class="mb-0 text-warning">₹@((summary?.TotalPending ?? 0).ToString("N0"))</h3>
                            </div>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="row">
                    <!-- Left: Customer + Medicine Search -->
                    <div class="col-md-5">
                        <!-- Customer Section -->
                        <div class="card">
                            <div class="card-header bg-primary text-white">
                                <i class="fas fa-user me-2"></i> Customer Details
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label">Search by Mobile Number</label>
                                    <input type="text" id="searchMobile" class="form-control" placeholder="Enter mobile number...">
                                    <div id="customerResults" class="list-group mt-2" style="display:none;"></div>
                                </div>

                                <div id="customerInfo" style="display:none;">
                                    <input type="hidden" id="customerId">
                                    <div class="mb-2">
                                        <strong>Name:</strong> <span id="displayName"></span>
                                    </div>
                                    <div class="mb-2">
                                        <strong>Mobile:</strong> <span id="displayMobile"></span>
                                    </div>

                                    <div class="mt-2">
                                        <button class="btn btn-info btn-sm" onclick="viewHistory($('#customerId').val())">
                                            <i class="fas fa-history me-1"></i> View Purchase History
                                        </button>
                                    </div>

                                    <!-- Pending Bills Section -->
                                    <div id="pendingBillsSection" class="mt-3" style="display:none;">
                                        <div class="alert alert-warning">
                                            <i class="fas fa-exclamation-triangle me-2"></i>
                                            <strong>Pending Amount: ₹<span id="totalPendingAmount">0</span></strong>
                                            <small class="d-block">Customer has unpaid bills. Please collect payment.</small>
                                        </div>

                                        <div class="table-responsive">
                                            <table class="table table-sm table-bordered">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Bill No</th>
                                                        <th>Date</th>
                                                        <th>Total</th>
                                                        <th>Paid</th>
                                                        <th>Due</th>
                                                        <th>Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="pendingBillsList"></tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                                <div id="newCustomerForm" style="display:none;">
                                    <div class="mb-2">
                                        <input type="text" id="newName" class="form-control" placeholder="Full Name *">
                                    </div>
                                    <div class="mb-2">
                                        <input type="text" id="newMobile" class="form-control" placeholder="Mobile Number *">
                                    </div>
                                    <div class="mb-2">
                                        <textarea id="newAddress" class="form-control" placeholder="Address (optional)" rows="2"></textarea>
                                    </div>
                                    <button class="btn btn-success btn-sm" onclick="createNewCustomer()">Add Customer</button>
                                </div>
                            </div>
                        </div>

                        <!-- Medicine Search -->
                        <div class="card mt-3">
                            <div class="card-header bg-info text-white">
                                <i class="fas fa-pills me-2"></i> Add Medicine
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label">Search Medicine</label>
                                    <input type="text" id="searchMedicine" class="form-control" placeholder="Type medicine name...">
                                    <div id="medicineResults" class="list-group mt-2" style="display:none;"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Cart + Bill -->
                    <div class="col-md-7">
                        <div class="card">
                            <div class="card-header bg-dark text-white">
                                <i class="fas fa-shopping-cart me-2"></i> Cart
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-bordered">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Medicine</th>
                                                <th width="80">Qty</th>
                                                <th width="100">Price</th>
                                                <th width="100">Total</th>
                                                <th width="40"></th>
                                            </tr>
                                        </thead>
                                        <tbody id="cartBody">
                                            <tr id="emptyCartRow">
                                                <td colspan="5" class="text-center text-muted py-3">No items added</td>
                                            </tr>
                                        </tbody>
                                        <tfoot id="cartFooter" style="display:none;">
                                            <tr class="table-light">
                                                <td colspan="3" class="text-end"><strong>Sub Total:</strong></td>
                                                <td><strong id="subTotal">₹0</strong></td>
                                                <td></td>
                                            </tr>
                                            <tr>
                                                <td colspan="2">
                                                    <select id="discountType" class="form-select form-select-sm">
                                                        <option value="Percentage">% Discount</option>
                                                        <option value="Fixed">₹ Discount</option>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input type="number" id="discountValue" class="form-control form-control-sm" placeholder="Value" value="0" step="0.01">
                                                </td>
                                                <td><strong id="discountAmount">₹0</strong></td>
                                                <td></td>
                                            </tr>
                                            <tr class="table-primary">
                                                <td colspan="3" class="text-end"><strong>Grand Total:</strong></td>
                                                <td><strong id="grandTotal">₹0</strong></td>
                                                <td></td>
                                            </tr>
                                            <tr>
                                                <td colspan="2">
                                                    <select id="paymentMode" class="form-select">
                                                        <option value="Cash">Cash</option>
                                                        <option value="Card">Card</option>
                                                        <option value="UPI">UPI</option>
                                                        <option value="Pending">Pending Payment</option>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input type="number" id="paidAmount" class="form-control" placeholder="Paid Amount" value="0" step="0.01">
                                                </td>
                                                <td><strong id="dueAmount">₹0</strong></td>
                                                <td></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>

                                <div class="mt-3 text-end">
                                    <button class="btn btn-success btn-lg" id="generateBillBtn" onclick="generateBill()" style="display:none;">
                                        <i class="fas fa-file-invoice me-2"></i> Generate Bill
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Collect Payment Modal -->
<div class="modal fade" id="collectPaymentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-money-bill me-2"></i> Collect Payment</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="paymentBillId">
                <div class="mb-3">
                    <label>Bill Number</label>
                    <input type="text" id="paymentBillNumber" class="form-control" readonly>
                </div>
                <div class="mb-3">
                    <label>Total Amount</label>
                    <input type="text" id="paymentTotalAmount" class="form-control" readonly>
                </div>
                <div class="mb-3">
                    <label>Already Paid</label>
                    <input type="text" id="paymentAlreadyPaid" class="form-control" readonly>
                </div>
                <div class="mb-3">
                    <label>Pending Amount</label>
                    <input type="text" id="paymentPendingAmount" class="form-control bg-warning bg-opacity-25" readonly>
                </div>
                <div class="mb-3">
                    <label>Enter Amount to Collect</label>
                    <input type="number" id="paymentCollectAmount" class="form-control" placeholder="Enter amount" step="0.01">
                </div>
                <div class="mb-3">
                    <label>Payment Mode</label>
                    <select id="paymentModeSelect" class="form-select">
                        <option value="Cash">Cash</option>
                        <option value="Card">Card</option>
                        <option value="UPI">UPI</option>
                    </select>
                </div>
                <div id="paymentError" class="alert alert-danger small" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" onclick="submitPayment()">Collect Payment</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let cart = [];
        let selectedCustomer = null;

        // Search Customer
        let searchTimer;
        $('#searchMobile').on('keyup', function() {
            clearTimeout(searchTimer);
            let search = $(this).val();
            if (search.length < 3) {
                $('#customerResults').hide();
                return;
            }
            searchTimer = setTimeout(() => {
                $.ajax({
                    url: '/Counter/SearchCustomer',
                    type: 'GET',
                    data: { search: search },
                    success: function(data) {
                        if (data && data.length > 0) {
                            let html = '';
                            data.forEach(c => {
                                let warning = '';
                                if (c.pendingBillCount > 0) {
                                    warning = `<span class="badge bg-warning ms-2">Pending: ₹${c.totalPendingAmount}</span>`;
                                }
                                html += `<a href="#" class="list-group-item list-group-item-action"
                                            onclick="selectCustomer(${c.customerId}, '${c.customerName.replace(/'/g, "\\'")}', '${c.mobileNumber}', ${c.pendingBillCount}, ${c.totalPendingAmount})">
                                            <strong>${c.customerName}</strong> - ${c.mobileNumber} ${warning}
                                        </a>`;
                            });
                            $('#customerResults').html(html).show();
                        } else {
                            $('#customerResults').html('<a href="#" class="list-group-item list-group-item-action" onclick="showNewCustomerForm()">+ New Customer</a>').show();
                        }
                    }
                });
            }, 500);
        });

        function selectCustomer(id, name, mobile, pendingCount, pendingAmount) {
            selectedCustomer = { id: id, name: name, mobile: mobile };
            $('#customerId').val(id);
            $('#displayName').text(name);
            $('#displayMobile').text(mobile);
            $('#customerInfo').show();
            $('#newCustomerForm').hide();
            $('#customerResults').hide();
            $('#searchMobile').val(mobile);

            if (pendingCount > 0) {
                $('#totalPendingAmount').text(pendingAmount.toFixed(2));
                $('#pendingBillsSection').show();

                // Load pending bills
                $.ajax({
                    url: '/Counter/GetPendingBills',
                    type: 'GET',
                    data: { customerId: id },
                    success: function(bills) {
                        let html = '';
                        if (bills && bills.length > 0) {
                            bills.forEach(b => {
                                html += `<tr>
                                    <td>${b.billNumber}</td>
                                    <td>${new Date(b.billDate).toLocaleDateString()}</td>
                                    <td>₹${b.totalAmount.toFixed(2)}</td>
                                    <td>₹${b.paidAmount.toFixed(2)}</td>
                                    <td class="text-danger fw-bold">₹${b.dueAmount.toFixed(2)}</td>
                                    <td>
                                        <button class="btn btn-sm btn-success" onclick="showCollectPayment(${b.billId}, '${b.billNumber}', ${b.totalAmount}, ${b.paidAmount}, ${b.dueAmount})">
                                            <i class="fas fa-money-bill me-1"></i> Collect
                                        </button>
                                    </td>
                                </tr>`;
                            });
                        } else {
                            html = `<tr><td colspan="6" class="text-center text-muted">No pending bills</td></tr>`;
                        }
                        $('#pendingBillsList').html(html);
                    }
                });
            } else {
                $('#pendingBillsSection').hide();
            }

            updateCartUI();
        }

        function showNewCustomerForm() {
            $('#customerInfo').hide();
            $('#newCustomerForm').show();
            $('#customerResults').hide();
            $('#newMobile').val($('#searchMobile').val());
        }

        function createNewCustomer() {
            let name = $('#newName').val().trim();
            let mobile = $('#newMobile').val().trim();
            let address = $('#newAddress').val();

            if (!name || !mobile) {
                alert('Please enter name and mobile number');
                return;
            }

            $.ajax({
                url: '/Counter/CreateCustomer',
                type: 'POST',
                data: { customerName: name, mobileNumber: mobile, address: address },
                success: function(res) {
                    if (res.success) {
                        selectedCustomer = { id: res.customerId, name: res.customerName, mobile: mobile };
                        $('#customerId').val(res.customerId);
                        $('#displayName').text(res.customerName);
                        $('#displayMobile').text(mobile);
                        $('#customerInfo').show();
                        $('#newCustomerForm').hide();
                        $('#searchMobile').val(mobile);
                        $('#pendingBillsSection').hide();
                        updateCartUI();
                    } else {
                        alert(res.message);
                    }
                }
            });
        }

        function showCollectPayment(billId, billNumber, totalAmount, paidAmount, dueAmount) {
            $('#paymentBillId').val(billId);
            $('#paymentBillNumber').val(billNumber);
            $('#paymentTotalAmount').val('₹' + totalAmount.toFixed(2));
            $('#paymentAlreadyPaid').val('₹' + paidAmount.toFixed(2));
            $('#paymentPendingAmount').val('₹' + dueAmount.toFixed(2));
            $('#paymentCollectAmount').val(dueAmount);
            $('#paymentError').hide();

            var modal = new bootstrap.Modal(document.getElementById('collectPaymentModal'));
            modal.show();
        }

               function submitPayment() {
            let billId = $('#paymentBillId').val();
            let collectAmount = parseFloat($('#paymentCollectAmount').val());
            let pendingAmountText = $('#paymentPendingAmount').val();
            let pendingAmount = parseFloat(pendingAmountText.replace('₹', ''));
            let paymentMode = $('#paymentModeSelect').val();

            // Validation
            if (isNaN(collectAmount) || collectAmount <= 0) {
                $('#paymentError').text('Please enter valid amount').show();
                return;
            }

            if (collectAmount > pendingAmount) {
                $('#paymentError').text('Amount cannot exceed pending amount').show();
                return;
            }

            // Disable button and show loading
            let submitBtn = $('#collectPaymentModal .btn-success');
            let originalText = submitBtn.text();
            submitBtn.prop('disabled', true).text('Processing...');
            $('#paymentError').hide();

            $.ajax({
                url: '/Counter/CollectPayment',
                type: 'POST',
                data: {
                    billId: billId,
                    amount: collectAmount,
                    paymentMode: paymentMode
                },
                success: function(res) {
                    submitBtn.prop('disabled', false).text(originalText);

                    if (res.success) {
                        $('#collectPaymentModal').modal('hide');

                        // Show success toast or alert
                        toastr.success('Payment collected successfully!');

                        // Refresh customer data
                        let mobile = $('#searchMobile').val();
                        if (mobile) {
                            $('#searchMobile').trigger('keyup');
                        }

                        // Also refresh the current customer view
                        let customerId = $('#customerId').val();
                        if (customerId) {
                            $.ajax({
                                url: '/Counter/GetPendingBills',
                                type: 'GET',
                                data: { customerId: customerId },
                                success: function(bills) {
                                    let totalPending = 0;
                                    let html = '';
                                    if (bills && bills.length > 0) {
                                        bills.forEach(b => {
                                            totalPending += b.dueAmount;
                                            html += `<tr>
                                                <td>${b.billNumber}</td>
                                                <td>${new Date(b.billDate).toLocaleDateString()}</td>
                                                <td>₹${b.totalAmount.toFixed(2)}</td>
                                                <td>₹${b.paidAmount.toFixed(2)}</td>
                                                <td class="text-danger fw-bold">₹${b.dueAmount.toFixed(2)}</td>
                                                <td>
                                                    <button class="btn btn-sm btn-success" onclick="showCollectPayment(${b.billId}, '${b.billNumber}', ${b.totalAmount}, ${b.paidAmount}, ${b.dueAmount})">
                                                        <i class="fas fa-money-bill me-1"></i> Collect
                                                    </button>
                                                </td>
                                            </tr>`;
                                        });
                                    } else {
                                        html = `<tr><td colspan="6" class="text-center text-success">No pending bills! All cleared.</td></tr>`;
                                    }
                                    $('#pendingBillsList').html(html);
                                    $('#totalPendingAmount').text(totalPending.toFixed(2));

                                    if (totalPending === 0) {
                                        $('#pendingBillsSection').hide();
                                    }
                                }
                            });
                        }
                    } else {
                        $('#paymentError').text(res.message || 'Payment failed').show();
                    }
                },
                error: function(xhr, status, error) {
                    submitBtn.prop('disabled', false).text(originalText);
                    let errorMsg = xhr.responseJSON?.message || 'Error processing payment. Please try again.';
                    $('#paymentError').text(errorMsg).show();
                }
            });
        }

        // Search Medicine
        $('#searchMedicine').on('keyup', function() {
            let search = $(this).val();
            if (search.length < 2) {
                $('#medicineResults').hide();
                return;
            }
            $.ajax({
                url: '/Counter/SearchMedicine',
                type: 'GET',
                data: { search: search },
                success: function(data) {
                    if (data && data.length > 0) {
                        let html = '';
                        data.forEach(m => {
                            let stockClass = m.stockQuantity < 10 ? 'text-danger' : 'text-success';
                            html += `<a href="#" class="list-group-item list-group-item-action"
                                        onclick="addToCart(${m.medicineId}, '${m.medicineName.replace(/'/g, "\\'")}', ${m.sellingPrice}, ${m.stockQuantity})">
                                        <div class="d-flex justify-content-between">
                                            <div><strong>${m.medicineName}</strong><br><small>MRP: ₹${m.mrp} | Selling: ₹${m.sellingPrice}</small></div>
                                            <div class="${stockClass}">Stock: ${m.stockQuantity}</div>
                                        </div>
                                    </a>`;
                        });
                        $('#medicineResults').html(html).show();
                    } else {
                        $('#medicineResults').html('<div class="list-group-item text-muted">No medicines found</div>').show();
                    }
                }
            });
        });

        // Cart functions
        function addToCart(id, name, price, stock) {
            let existing = cart.find(c => c.id === id);
            if (existing) {
                if (existing.qty + 1 > stock) {
                    alert(`Only ${stock} units available in stock`);
                    return;
                }
                existing.qty++;
            } else {
                if (1 > stock) {
                    alert(`Only ${stock} units available`);
                    return;
                }
                cart.push({ id: id, name: name, price: price, qty: 1, maxStock: stock });
            }
            updateCartUI();
            $('#searchMedicine').val('');
            $('#medicineResults').hide();
        }

        function removeFromCart(index) {
            cart.splice(index, 1);
            updateCartUI();
        }

        function updateQuantity(index, newQty) {
            let item = cart[index];
            if (newQty < 1) newQty = 1;
            if (newQty > item.maxStock) {
                alert(`Only ${item.maxStock} units available`);
                newQty = item.maxStock;
            }
            item.qty = newQty;
            updateCartUI();
        }

        function updateCartUI() {
            let subTotal = 0;
            let html = '';

            if (cart.length === 0) {
                html = '<tr id="emptyCartRow"><td colspan="5" class="text-center text-muted py-3">No items added</td></tr>';
                $('#cartBody').html(html);
                $('#cartFooter').hide();
                $('#generateBillBtn').hide();
                return;
            }

            cart.forEach((item, idx) => {
                let total = item.qty * item.price;
                subTotal += total;
                html += `<tr>
                            <td>${item.name}</td>
                            <td><input type="number" class="form-control form-control-sm" value="${item.qty}" min="1" max="${item.maxStock}" style="width:70px" onchange="updateQuantity(${idx}, this.value)"></td>
                            <td>₹${item.price}</td>
                            <td>₹${total.toFixed(2)}</td>
                            <td><button class="btn btn-sm btn-danger" onclick="removeFromCart(${idx})">✕</button></td>
                        </tr>`;
            });

            $('#cartBody').html(html);
            $('#subTotal').text('₹' + subTotal.toFixed(2));
            calculateDiscount(subTotal);
            $('#cartFooter').show();

            if (selectedCustomer) {
                $('#generateBillBtn').show();
            } else {
                $('#generateBillBtn').hide();
            }
        }

        function calculateDiscount(subTotal) {
            let discountType = $('#discountType').val();
            let discountValue = parseFloat($('#discountValue').val()) || 0;
            let discountAmount = 0;

            if (discountType === 'Percentage') {
                discountAmount = subTotal * (discountValue / 100);
            } else {
                discountAmount = discountValue;
            }

            if (discountAmount > subTotal) discountAmount = subTotal;

            let grandTotal = subTotal - discountAmount;

            $('#discountAmount').text('₹' + discountAmount.toFixed(2));
            $('#grandTotal').text('₹' + grandTotal.toFixed(2));

            let paid = parseFloat($('#paidAmount').val()) || 0;
            let due = grandTotal - paid;
            if (due < 0) due = 0;
            $('#dueAmount').text('₹' + due.toFixed(2));

            return { subTotal, discountAmount, grandTotal };
        }

        $('#discountType, #discountValue').on('change keyup', function() {
            let subTotal = 0;
            cart.forEach(item => subTotal += item.qty * item.price);
            calculateDiscount(subTotal);
        });

        $('#paidAmount').on('keyup', function() {
            let grandTotal = parseFloat($('#grandTotal').text().replace('₹', ''));
            let paid = parseFloat($(this).val()) || 0;
            let due = grandTotal - paid;
            if (due < 0) due = 0;
            $('#dueAmount').text('₹' + due.toFixed(2));
        });

        function generateBill() {
            if (!selectedCustomer) {
                alert('Please select a customer first');
                return;
            }
            if (cart.length === 0) {
                alert('Cart is empty');
                return;
            }

            let subTotal = 0;
            cart.forEach(item => subTotal += item.qty * item.price);
            let discountType = $('#discountType').val();
            let discountValue = parseFloat($('#discountValue').val()) || 0;
            let discountAmount = 0;

            if (discountType === 'Percentage') {
                discountAmount = subTotal * (discountValue / 100);
            } else {
                discountAmount = discountValue;
            }
            if (discountAmount > subTotal) discountAmount = subTotal;

            let grandTotal = subTotal - discountAmount;
            let paymentMode = $('#paymentMode').val();
            let paidAmount = parseFloat($('#paidAmount').val()) || 0;
            if (paidAmount > grandTotal) paidAmount = grandTotal;
            let dueAmount = grandTotal - paidAmount;

            let request = {
                customerId: selectedCustomer.id,
                customerName: selectedCustomer.name,
                mobileNumber: selectedCustomer.mobile,
                subTotal: subTotal,
                discountType: discountType,
                discountValue: discountValue,
                discountAmount: discountAmount,
                totalAmount: grandTotal,
                paymentMode: paymentMode,
                paidAmount: paidAmount,
                dueAmount: dueAmount,
                cartItems: cart.map(c => ({
                    medicineId: c.id,
                    medicineName: c.name,
                    quantity: c.qty,
                    unitPrice: c.price,
                    maxStock: c.maxStock
                }))
            };

            $('#generateBillBtn').prop('disabled', true).text('Processing...');

            $.ajax({
                url: '/Counter/SaveBill',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(request),
                success: function(res) {
                    if (res.success) {
                        window.open('/Counter/PrintBill?id=' + res.billId, '_blank');
                        // Reset
                        cart = [];
                        selectedCustomer = null;
                        $('#customerId').val('');
                        $('#customerInfo').hide();
                        $('#searchMobile').val('');
                        $('#pendingBillsSection').hide();
                        $('#paidAmount').val(0);
                        $('#discountValue').val(0);
                        updateCartUI();
                        // Refresh summary
                        location.reload();
                    } else {
                        alert(res.message);
                        $('#generateBillBtn').prop('disabled', false).text('Generate Bill');
                    }
                },
                error: function() {
                    alert('Error generating bill');
                    $('#generateBillBtn').prop('disabled', false).text('Generate Bill');
                }
            });
        }

        // Close dropdowns when clicking outside
        $(document).click(function(e) {
            if (!$(e.target).closest('#searchMobile, #customerResults').length) {
                $('#customerResults').hide();
            }
            if (!$(e.target).closest('#searchMedicine, #medicineResults').length) {
                $('#medicineResults').hide();
            }
        });

                       function viewHistory() {
            let customerId = $('#customerId').val();
            let customerName = $('#displayName').text();

            if (customerId && customerId > 0) {
                // Debug: Check what ID is being passed
                console.log("Viewing history for Customer ID:", customerId, "Name:", customerName);
                window.location.href = '/Counter/CustomerHistory?id=' + customerId;
            } else {
                alert('Please select a customer first');
            }
        }
    </script>
}