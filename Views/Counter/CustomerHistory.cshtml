@using WebApplicationSampleTest2.Models
@{
    ViewData["Title"] = "Customer Purchase History";
    var customer = ViewBag.Customer as CounterCustomerModel;
    var bills = ViewBag.Bills as List<CounterBillModel>;
    var items = ViewBag.Items as List<CounterBillItemModel>;
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <i class="fas fa-history me-2"></i> Customer Purchase History
            </div>
            <div class="card-body">

                <!-- Customer Info -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h5 class="card-title"><i class="fas fa-user me-2"></i>Customer Details</h5>
                                <p class="mb-1"><strong>Name:</strong> @customer?.CustomerName</p>
                                <p class="mb-1"><strong>Mobile:</strong> @customer?.MobileNumber</p>
                                <p class="mb-0"><strong>Address:</strong> @customer?.Address</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h5 class="card-title"><i class="fas fa-chart-line me-2"></i>Summary</h5>
                                <p class="mb-1"><strong>Total Bills:</strong> @(bills?.Count ?? 0)</p>
                                <p class="mb-1"><strong>Total Spent:</strong> ₹@(bills?.Sum(b => b.TotalAmount).ToString("N0") ?? "0")</p>
                                <p class="mb-0"><strong>Total Items Purchased:</strong> @(items?.Sum(i => i.Quantity) ?? 0)</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Bills Table -->
                <h5 class="mt-3"><i class="fas fa-receipt me-2"></i>Bill History</h5>
                <div class="table-responsive">
                    <table class="table table-striped table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Bill No</th>
                                <th>Date</th>
                                <th>Total Amount</th>
                                <th>Paid</th>
                                <th>Due</th>
                                <th>Status</th>
                                <th>Payment Mode</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (bills != null && bills.Any())
                            {
                                foreach (var bill in bills)
                                {
                                    var statusClass = bill.PaymentStatus == "Paid" ? "text-success" : (bill.PaymentStatus == "Partial" ? "text-warning" : "text-danger");
                                    <tr>
                                        <td><b>@bill.BillNumber</b></td>
                                        <td>@bill.BillDate.ToString("dd/MM/yyyy hh:mm tt")</td>
                                        <td>₹@bill.TotalAmount.ToString("0.00")</td>
                                        <td>₹@bill.PaidAmount.ToString("0.00")</td>
                                        <td>₹@bill.DueAmount.ToString("0.00")</td>
                                        <td class="@statusClass">@bill.PaymentStatus</td>
                                        <td>@bill.PaymentMode</td>
                                        <td>
                                            <button class="btn btn-sm btn-info" onclick="showBillDetails(@bill.BillId, '@bill.BillNumber')">
                                                <i class="fas fa-eye me-1"></i> View Items
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center text-muted py-4">
                                        <i class="fas fa-shopping-bag fa-2x mb-2 d-block"></i>
                                        No purchase history found
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3">
                    <a href="/Counter/Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Back to Counter
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- Bill Items Modal -->
<div class="modal fade" id="billItemsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="fas fa-pills me-2"></i>Bill Items: <span id="modalBillNumber"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Medicine Name</th>
                                <th>Quantity</th>
                                <th>Unit Price</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody id="billItemsList"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Store all items for lookup
        let allItems = @Html.Raw(Json.Serialize(items ?? new List<CounterBillItemModel>()));

        function showBillDetails(billId, billNumber) {
            $('#modalBillNumber').text(billNumber);

            let filteredItems = allItems.filter(i => i.billId === billId);

            let html = '';
            if (filteredItems.length > 0) {
                filteredItems.forEach(item => {
                    html += `<tr>
                        <td>${item.medicineName}</td>
                        <td>${item.quantity}</td>
                        <td>₹${item.unitPrice.toFixed(2)}</td>
                        <td>₹${item.totalPrice.toFixed(2)}</td>
                    </tr>`;
                });
            } else {
                html = `<tr><td colspan="4" class="text-center text-muted">No items found for this bill</td></tr>`;
            }

            $('#billItemsList').html(html);

            var modal = new bootstrap.Modal(document.getElementById('billItemsModal'));
            modal.show();
        }
    </script>
}