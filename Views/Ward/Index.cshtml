@model List<WebApplicationSampleTest2.Models.WardListVM>


@{
    ViewBag.Title = "Wards List";
    // ViewBag.pTitle = "Form Advanced";
    // ViewBag.pageTitle = "Forms";
    // Layout = "~/Views/_Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Wards</h4>
                <p class="card-title-desc">List of all wards in the hospital.</p>

                <div class="row mb-3">
                    <div class="col-12 d-flex justify-content-end">
                        <a asp-action="Create" class="btn btn-primary mb-3">Add New Ward</a>
                    </div>
                </div>




                @if (Model != null && Model.Any())
                {
                    <table class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>Ward Name</th>
                                <th>Ward Type</th>
                                <th>Floor Number</th>
                                <th>Total Rooms</th>
                                <th>Total Beds</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ward in Model)
                            {
                                <tr>
                                    <td>@ward.WardName</td>
                                    <td>@ward.WardType</td>
                                    <td>@ward.FloorNumber</td>
                                    <td>@ward.TotalRooms</td>
                                    <td>@ward.TotalBeds</td>
                                    <td>@ward.Description</td>
                                    <td>@(ward.IsActive ? "Active" : "Inactive")</td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@ward.WardId" class="btn btn-primary btn-sm">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@ward.WardId" class="btn btn-danger btn-sm">Delete</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-info">No wards found.</div>
                }
            </div>
        </div>
    </div>
</div>