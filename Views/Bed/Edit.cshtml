@model WebApplicationSampleTest2.Models.Bed

@{
    ViewBag.Title = "Edit Bed";
}

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">

                <h4 class="card-title mb-4">Edit Bed</h4>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="BedId" />
                    <input type="hidden" asp-for="WardId" />
                    <input type="hidden" asp-for="RoomId" />

                    <div class="row">

                        <!-- Bed Number -->
                        <div class="col-lg-6 mb-3">
                            <label asp-for="BedNumber" class="form-label"></label>
                            <input asp-for="BedNumber" class="form-control" />
                            <span asp-validation-for="BedNumber" class="text-danger"></span>
                        </div>

                        <!-- Charges Per Day -->
                        <div class="col-lg-6 mb-3">
                            <label asp-for="ChargesPerDay" class="form-label"></label>
                            <input asp-for="ChargesPerDay"
                                   class="form-control"
                                   type="number"
                                   step="0.01"
                                   min="0" />
                            <span asp-validation-for="ChargesPerDay" class="text-danger"></span>
                        </div>

                        <!-- Status -->
                        <div class="col-lg-6 mb-3">
                            <label asp-for="OperationalStatus" class="form-label">Status</label>
                            <select asp-for="OperationalStatus"
                                    asp-items="@(new SelectList(ViewBag.StatusList))"
                                    class="form-control">
                            </select>
                        </div>

                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">Update</button>
                        <a asp-action="Index"
                           asp-route-wardId="@Model.WardId"
                           asp-route-roomId="@Model.RoomId"
                           class="btn btn-secondary">Cancel</a>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>