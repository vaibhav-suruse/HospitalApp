@model WebApplicationSampleTest2.Models.Bed

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Create Bed";
}

@section styles {
    <link href="~/assets/libs/select2/css/select2.min.css" rel="stylesheet" />
}

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">

                <h4 class="card-title">Create Bed</h4>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Create" method="post">
                    <div class="row">

                        @* <!-- Ward Dropdown -->
                        <div class="col-lg-6 mb-3">
                            <label asp-for="WardId" class="form-label">Ward</label>
                            <select asp-for="WardId"
                                    asp-items="ViewBag.Wards"
                                    class="form-control select2"
                                    id="WardId">
                                <option value="">Select Ward</option>
                            </select>
                            <span asp-validation-for="WardId" class="text-danger"></span>
                        </div>

                        <!-- Room Dropdown -->
                        <div class="col-lg-6 mb-3">
                            <label asp-for="RoomId" class="form-label">Room</label>
                            <select asp-for="RoomId"
                                    class="form-control select2"
                                    id="RoomId">
                                <option value="">Select Room</option>
                            </select>
                            <span asp-validation-for="RoomId" class="text-danger"></span>
                        </div> *@




                        <!-- Ward Dropdown -->
                        <div class="col-lg-6 mb-3">
                            <label asp-for="WardId" class="form-label">Ward</label>
                            <select asp-for="WardId"
                                    asp-items="ViewBag.Wards"
                                    class="form-control select"
                                    id="WardId">
                                <option value="">Select Ward</option>
                            </select>
                            <span asp-validation-for="WardId" class="text-danger"></span>
                        </div>

                        <!-- Room Dropdown -->
                        <div class="col-lg-6 mb-3">
                            <label asp-for="RoomId" class="form-label">Room</label>
                            <select asp-for="RoomId"
                                    class="form-control select"
                                    id="RoomId">
                                <option value="">Select Room</option>
                                @* Items will be populated dynamically *@
                            </select>
                            <span asp-validation-for="RoomId" class="text-danger"></span>
                        </div>



                        <!-- Bed Number -->
                        <div class="col-lg-6 mb-3">
                            <label asp-for="BedNumber" class="form-label">Bed Number</label>
                            <input asp-for="BedNumber" class="form-control" />
                            <span asp-validation-for="BedNumber" class="text-danger"></span>
                        </div>

                        <div class="col-lg-6 mb-3">
                            <label asp-for="ChargesPerDay" class="form-label"></label>
                            <input asp-for="ChargesPerDay"
                                   class="form-control"
                                   type="number"
                                   step="0.01"
                                   min="0" />
                            <span asp-validation-for="ChargesPerDay" class="text-danger"></span>
                        </div>

                        <div class="col-lg-6 mb-3">
                            <label asp-for="OperationalStatus" class="form-label">Occupied</label>
                            <select asp-for="OperationalStatus"
                                    asp-items="@(new SelectList(ViewBag.StatusList))"
                                    class="form-control">
                            </select>
                        </div>


                    </div>

                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </form>

            </div>
        </div>
    </div>
</div>




<script>
    document.addEventListener("DOMContentLoaded", function () {

        var wardDropdown = document.getElementById("WardId");
        var roomDropdown = document.getElementById("RoomId");

        // Populate rooms when Ward changes
        wardDropdown.addEventListener("change", function () {
            var wardId = this.value;

            roomDropdown.innerHTML = '<option value="">Loading...</option>';

            if (!wardId) {
                roomDropdown.innerHTML = '<option value="">Select Room</option>';
                return;
            }

            fetch('/Bed/GetRoomsByWard?wardId=' + wardId)
                .then(response => {
                    if (!response.ok) throw new Error("Network response was not ok");
                    return response.json();
                })
                .then(data => {
                    roomDropdown.innerHTML = '<option value="">Select Room</option>';
                    data.forEach(function (room) {
                        var option = document.createElement("option");
                        option.value = room.roomId;
                        option.textContent = room.roomNumber;
                        roomDropdown.appendChild(option);
                    });
                })
                .catch(error => {
                    console.error('Error fetching rooms:', error);
                    roomDropdown.innerHTML = '<option value="">Error loading rooms</option>';
                });
        });

        // If a ward is pre-selected (edit scenario), populate rooms automatically
        var initialWardId = wardDropdown.value;
        var initialRoomId = '@Model?.RoomId';

        if (initialWardId) {
            fetch('/Bed/GetRoomsByWard?wardId=' + initialWardId)
                .then(response => response.json())
                .then(data => {
                    roomDropdown.innerHTML = '<option value="">Select Room</option>';
                    data.forEach(function (room) {
                        var option = document.createElement("option");
                        option.value = room.roomId;
                        option.textContent = room.roomNumber;
                        if (room.roomId == initialRoomId) option.selected = true;
                        roomDropdown.appendChild(option);
                    });
                })
                .catch(error => {
                    roomDropdown.innerHTML = '<option value="">Error loading rooms</option>';
                });
        }

    });
</script>