@model WebApplicationSampleTest2.Models.Room

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Add Room";
}

@section styles {
    <link href="~/assets/libs/select2/css/select2.min.css" rel="stylesheet" />
}

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">

                <h4 class="card-title">Add Room</h4>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                @* Server-side validation summary *@
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <form asp-action="Create" method="post">
                    <div class="row">

                        <div class="col-lg-6 mb-3">
                            <label asp-for="WardId" class="form-label">Select Ward</label>
                            <select asp-for="WardId" class="form-control select2-no-search" asp-items="ViewBag.Wards">
                                <option value="">-- Select Ward --</option>
                            </select>
                            <span asp-validation-for="WardId" class="text-danger"></span>
                        </div>

                        <div class="col-lg-6 mb-3">
                            <label asp-for="RoomNumber" class="form-label">Room Number</label>
                            <input asp-for="RoomNumber" class="form-control" />
                            <span asp-validation-for="RoomNumber" class="text-danger"></span>
                        </div>

                        <div class="col-lg-6 mb-3">
                            <label asp-for="RoomType" class="form-label">Room Type</label>
                            <select asp-for="RoomType" class="form-control select2-no-search" asp-items="ViewBag.RoomTypes">
                                <option value="">-- Select Room Type --</option>
                            </select>
                            <span asp-validation-for="RoomType" class="text-danger"></span>
                        </div>



                        <div class="col-lg-6 mb-3">
                            <label asp-for="IsActive" class="form-label">Status</label>
                            <select asp-for="IsActive" class="form-control select2">
                                <option value="true" selected>Active</option>
                                <option value="false">Inactive</option>
                            </select>
                            <span asp-validation-for="IsActive" class="text-danger"></span>
                        </div>

                        <div class="col-lg-6 mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>


                    </div>

                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Index" asp-route-wardId="@Model.WardId" class="btn btn-secondary">Cancel</a>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/assets/libs/select2/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.select2').select2();
        });
    </script>
}