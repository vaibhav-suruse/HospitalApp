@model List<InventoryModel>

<div class="d-flex justify-content-between mb-3">
    <h4>Inventory Management</h4>

    <div class="d-flex">
        <form method="get" asp-action="Index" class="d-flex me-2">
            <input type="text" name="search"
                   value="@ViewBag.Search"
                   class="form-control me-2"
                   placeholder="Search medicine..." />
        </form>

         <a class="btn btn-primary" asp-controller="Inventory" asp-action="Create">
        + Add Medicine
    </a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Medicine Name</th>
                <th>Category</th>
                <th>Stock</th>
                <th>Unit</th>
                <th>Expiry</th>
                <th>MRP</th>
                <th>Supplier</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                int i = 1;
                foreach (var item in Model)
                {
                    <tr>
                        <td>#@i</td>

                        <td><b>@item.MedicineName</b></td>

                        <td>@item.CategoryName</td>

                        <!-- STOCK WITH BAR -->
                        <td>
                            <span>@item.Stock</span>
                            <div class="progress" style="height:6px;">
                                <div class="progress-bar @(item.Status == "Low Stock" ? "bg-danger" : "bg-success")"
                                     style="width:@(item.Stock)%">
                                </div>
                            </div>
                        </td>

                        <td>@item.Unit</td>

                        <td>
                            @item.ExpiryDate?.ToString("MM/yyyy")
                        </td>

                        <td>₹@item.MRP</td>

                        <td>@item.SupplierName</td>

                        <!-- STATUS BADGE -->
                        <td>
                            @if (item.Status == "Low Stock")
                            {
                                <span class="badge bg-danger">⚠ Low Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-success">✔ In Stock</span>
                            }
                        </td>

                        <!-- ACTIONS -->
                        <td>
                           <a asp-action="Edit" asp-controller="Inventory" asp-route-batchId="@item.BatchId" asp-route-medicineId="@item.MedicineId"class="btn btn-sm btn-primary">Edit</a>
<button class="btn btn-sm btn-danger" onclick="confirmDelete('@item.BatchId','@item.MedicineId')"> Delete</button>                    </td>
                    </tr>

                    i++;
                }
            }
            else
            {
                <tr>
                    <td colspan="10" class="text-center text-muted">
                        No records found
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


