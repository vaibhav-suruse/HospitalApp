@section Scripts {
<script src="~/assets/libs/apexcharts/apexcharts.min.js"></script>
<script>
/* ── Clock ── */
(function tick(){
    const n=new Date(), p=v=>String(v).padStart(2,'0');
    document.getElementById('liveClock').textContent=`${p(n.getHours())}:${p(n.getMinutes())}:${p(n.getSeconds())}`;
    setTimeout(tick,1000);
})();

/* ── Animate number ── */
function animN(id, target, prefix){
    const el=document.getElementById(id); if(!el) return;
    prefix=prefix||'';
    const dur=900, t0=performance.now();
    (function step(now){
        const p=Math.min((now-t0)/dur,1), e=1-Math.pow(1-p,3);
        el.textContent=prefix+Math.floor(e*target).toLocaleString('en-IN');
        if(p<1) requestAnimationFrame(step);
        else el.textContent=prefix+target.toLocaleString('en-IN');
    })(t0);
}

/* ── Chart ── */
let chart=null;
const wData=[12,18,15,24,20,28,22];
const chartMap={
    week : [['Mon','Tue','Wed','Thu','Fri','Sat','Sun'], wData],
    month: [['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],[110,130,155,142,175,190,168,210,185,225,200,245]],
    year : [['2020','2021','2022','2023','2024'],[1200,1450,1750,2100,2600]]
};
function renderChart(type){
    const [cats,data]=chartMap[type];
    const opts={
        chart:{type:'area',height:265,toolbar:{show:false},zoom:{enabled:false},animations:{enabled:true,speed:500}},
        series:[{name:'Appointments',data}],
        xaxis:{categories:cats,labels:{style:{fontSize:'11px',colors:'#8a92a6'}},axisBorder:{show:false},axisTicks:{show:false}},
        yaxis:{labels:{style:{fontSize:'11px',colors:'#8a92a6'}}},
        colors:['#2b4acb'],
        fill:{type:'gradient',gradient:{shadeIntensity:1,opacityFrom:.3,opacityTo:.02,stops:[0,90,100]}},
        stroke:{curve:'smooth',width:2.5}, dataLabels:{enabled:false},
        grid:{borderColor:'#f0f2f8',strokeDashArray:4,xaxis:{lines:{show:false}}},
        tooltip:{y:{formatter:v=>v+' appts'}}
    };
    if(chart){ chart.updateOptions({xaxis:{categories:cats}}); chart.updateSeries([{name:'Appointments',data}]); }
    else { chart=new ApexCharts(document.querySelector('#dashChart'),opts); chart.render(); }
}
function switchChart(t){
    ['bW','bM','bY'].forEach(id=>document.getElementById(id).classList.remove('active'));
    document.getElementById({week:'bW',month:'bM',year:'bY'}[t]).classList.add('active');
    renderChart(t);
}
setInterval(()=>{
    wData.push(Math.floor(10+Math.random()*30)); wData.shift();
    if(chart) chart.updateSeries([{name:'Appointments',data:wData}]);
},7000);

/* ── Activity feed ── */
const tpls=[
    {ico:'bx bx-purchase-tag-alt',bg:'ib-green', txt:'New sale: ₹{amt}',           sub:'Pharmacy'},
    {ico:'bx bx-capsule',         bg:'ib-blue',  txt:'{med} dispensed — Token #{t}',sub:'OPD Pharmacy'},
    {ico:'bx bx-user',            bg:'ib-teal',  txt:'Patient {nm} vitals — {room}',sub:'Nurse Station'},
    {ico:'bx bx-receipt',         bg:'ib-purple',txt:'Bill #{bill} paid — ₹{amt}',  sub:'Billing'},
    {ico:'bx bx-error-circle',    bg:'ib-red',   txt:'Low stock: {med}',            sub:'Inventory'},
    {ico:'bx bxs-truck',          bg:'ib-orange',txt:'{sup} delivery confirmed',    sub:'Purchase'},
    {ico:'bx bx-calendar-check',  bg:'ib-blue',  txt:'Appt #{t} — Dr.{nm}',        sub:'Reception'}
];
const meds=['Paracetamol 500mg','Amoxicillin 250mg','Omeprazole 20mg','Metformin 500mg','Cetirizine 10mg'];
const nms=['Raj Sharma','Priya Patel','Vikram Nair','Anjali Singh','Suresh Kumar'];
const rms=['IPD A-07','IPD B-12','IPD C-03']; const sps=['Sun Pharma','Cipla','Lupin'];
const ri=a=>a[Math.floor(Math.random()*a.length)];
function mkTxt(tpl){
    return tpl.txt.replace('{amt}',Math.floor(150+Math.random()*2000))
        .replace('{med}',ri(meds)).replace('{t}',Math.floor(10+Math.random()*50))
        .replace('{nm}',ri(nms)).replace('{room}',ri(rms))
        .replace('{bill}',Math.floor(1000+Math.random()*200)).replace('{sup}',ri(sps));
}
function addAct(){
    const tpl=ri(tpls), feed=document.getElementById('actFeed');
    const d=document.createElement('div'); d.className='act-item';
    d.innerHTML=`<div class="act-ico ${tpl.bg}"><i class="${tpl.ico}"></i></div><div><div class="act-txt">${mkTxt(tpl)}</div><div class="act-time">${tpl.sub} &bull; Just now</div></div>`;
    feed.insertBefore(d,feed.firstChild);
    while(feed.children.length>12) feed.removeChild(feed.lastChild);
}
for(let i=0;i<5;i++) addAct();
(function sc(){ setTimeout(()=>{addAct();sc();}, 4000+Math.random()*3000); })();

/* ── Load real medicine stats ── */
$.ajax({
    url:'/Inventory/GetInventoryStats', type:'GET',
    success:function(d){
        // .NET Core JSON serializer returns camelCase by default
        animN('medTotal',   d.totalMedicines||0);
        animN('medLow',     d.lowStockCount||0);
        animN('medIn',      d.inStockCount||0);
        animN('medExpiry',  d.expiryIn30Days||0);
        $('#medBatchesSub').text((d.totalBatches||0)+' batches');
        $('#medUnitsSub').text((d.totalStockUnits||0).toLocaleString('en-IN')+' units available');
        $('#medExpiredSub').text((d.expiredCount||0)+' already expired');

        const tot=(d.inStockCount||0)+(d.lowStockCount||0)+(d.expiredCount||0);
        if(tot>0){
            const pI=Math.round(d.inStockCount/tot*100), pL=Math.round(d.lowStockCount/tot*100), pE=Math.round(d.expiredCount/tot*100);
            setTimeout(()=>{ $('#bIn').css('width',pI+'%'); $('#bLow').css('width',pL+'%'); $('#bExp').css('width',pE+'%'); },400);
            $('#pIn').text(pI+'%'); $('#pLow').text(pL+'%'); $('#pExp').text(pE+'%');
        }
        if(d.categoryBreakdown && d.categoryBreakdown.length){
            $('#medCats').html(d.categoryBreakdown.map(c=>
                `<span class="cat-chip">${c.category} <b style="color:#fff">${c.count}</b></span>`
            ).join(''));
        }
    },
    error:function(){ console.warn('Inventory stats unavailable'); }
});

/* ── Load appointment / patient stats ── */
$.ajax({
    url:'/DashBord/GetDashboardCounts', type:'GET',
    success:function(d){
        // camelCase from .NET Core JSON serializer
        animN('totalPatients', d.totalPatients||0);
        animN('todayAppts',    d.todayAppointments||0);
        animN('completedToday',d.todayCompleted||0);
        animN('pendingToday',  d.todayPending||0);
        animN('availDoctors',  d.todayAvailableDoctors||0);
        animN('billsCount',    d.totalAppointments||0);

        const rev=(d.todayCompleted||0)*450+Math.floor(Math.random()*2000);
        $('#todaySales').text('₹'+rev.toLocaleString('en-IN'));
        $('#sTrendSales').text('+₹'+Math.floor(rev*.08).toLocaleString('en-IN')+' vs yesterday');
        $('#sTrendPatients').text((d.totalPatients||0)+' registered');
        $('#sTrendAppts').text((d.todayCompleted||0)+' done · '+(d.todayPending||0)+' pending');
        $('#sTrendCompleted').text('out of '+(d.todayAppointments||0)+' today');
        $('#sTrendBills').text((d.todayCompleted||0)+' today');

        $('#sToday').text(d.todayAppointments||0);
        $('#sTodayD').text('✔ '+(d.todayCompleted||0)+' done  •  ⏳ '+(d.todayPending||0)+' pending');
        $('#sYest').text(d.yesterdayAppointments||0);
        $('#sYestD').text('✔ '+(d.yesterdayCompleted||0)+' done');
        $('#sTomr').text(d.tomorrowAppointments||0);
    }
});

