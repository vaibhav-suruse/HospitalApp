@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Dashboard";
    var userName = Context.Session.GetString("UserName") ?? "Admin";
}

<style>
.dash-topbar {
    background:#fff; border-radius:16px; padding:14px 24px;
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:24px; box-shadow:0 2px 12px rgba(0,0,0,.06);
}
.dash-topbar h2 { font-size:1.3rem; font-weight:800; color:#1a1f36; margin:0; }
.dash-topbar p  { font-size:.78rem; color:#8a92a6; margin:0; }

.live-pill {
    display:flex; align-items:center; gap:6px;
    background:#f0fff4; border:1px solid #b2f5d2;
    border-radius:20px; padding:5px 14px;
    font-size:.78rem; font-weight:700; color:#22a65a;
}
.live-dot {
    width:8px; height:8px; border-radius:50%; background:#22a65a;
    animation:pulseLive 1.6s infinite;
}
.clock-pill {
    background:#f5f7ff; border:1px solid #dde2ff; border-radius:20px;
    padding:5px 16px; font-size:.85rem; font-weight:800; color:#3d4aad;
    font-variant-numeric:tabular-nums; letter-spacing:.04em;
}
.topbar-icon-btn {
    width:36px; height:36px; border-radius:50%;
    background:#f5f7fa; border:none; cursor:pointer;
    display:flex; align-items:center; justify-content:center;
    color:#555; font-size:.95rem; position:relative; transition:background .15s;
}
.topbar-icon-btn:hover { background:#eef1ff; color:#2b4acb; }
.badge-dot { width:8px; height:8px; background:#f6a623; border-radius:50%; position:absolute; top:2px; right:2px; border:2px solid #fff; }
.user-btn {
    background:#2b4acb; color:#fff; border:none; border-radius:22px;
    padding:7px 18px 7px 10px; display:flex; align-items:center; gap:8px;
    font-size:.82rem; font-weight:600; cursor:pointer;
}
.user-avatar { width:26px; height:26px; background:rgba(255,255,255,.2); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.7rem; }

/* ── Regular stat cards ── */
.stat-card {
    background:#fff; border-radius:16px; padding:20px 20px 16px;
    position:relative; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,.05);
    transition:transform .2s, box-shadow .2s; height:100%;
}
.stat-card:hover { transform:translateY(-3px); box-shadow:0 8px 24px rgba(0,0,0,.1); }
.stat-card::before { content:''; position:absolute; left:0; top:0; bottom:0; width:4px; border-radius:16px 0 0 16px; }
.acc-blue::before   { background:#2b4acb; }
.acc-green::before  { background:#27ae60; }
.acc-orange::before { background:#f39c12; }
.acc-purple::before { background:#8e44ad; }
.acc-teal::before   { background:#1abc9c; }
.acc-red::before    { background:#e74c3c; }
.sicon { width:50px; height:50px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:1.35rem; margin-bottom:12px; }
.ib-blue   { background:#eef1ff; color:#2b4acb; }
.ib-green  { background:#f0fff6; color:#27ae60; }
.ib-orange { background:#fff8ec; color:#f39c12; }
.ib-teal   { background:#e8faf8; color:#1abc9c; }
.ib-purple { background:#f3eeff; color:#8e44ad; }
.ib-red    { background:#fff0f0; color:#e74c3c; }
.snum  { font-size:2rem; font-weight:800; color:#1a1f36; line-height:1; margin-bottom:4px; font-variant-numeric:tabular-nums; }
.slbl  { font-size:.8rem; color:#8a92a6; font-weight:500; margin-bottom:8px; }
.strend{ font-size:.74rem; font-weight:600; display:flex; align-items:center; gap:3px; }
.tup   { color:#27ae60; }
.tdown { color:#e74c3c; }
.twarn { color:#f39c12; }

/* ══════════════════════════════════
   MEDICINE PANEL — dark gradient
══════════════════════════════════ */
.med-panel {
    background: linear-gradient(135deg, #0d1b5e 0%, #1a3a8f 45%, #132f7a 100%);
    border-radius:20px; padding:26px 28px; color:#fff; position:relative;
    overflow:hidden; box-shadow:0 10px 40px rgba(13,27,94,.4); margin-bottom:24px;
}
.med-panel::before {
    content:''; position:absolute; top:-50px; right:-50px;
    width:220px; height:220px; background:rgba(255,255,255,.05); border-radius:50%;
}
.med-panel::after {
    content:''; position:absolute; bottom:-60px; left:38%;
    width:180px; height:180px; background:rgba(255,255,255,.04); border-radius:50%;
}
.med-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:22px; position:relative; z-index:1; }
.med-title  { font-size:1.02rem; font-weight:700; color:#fff; display:flex; align-items:center; gap:10px; }
.med-title i { font-size:1.25rem; color:#7eb8ff; }
.med-live-badge {
    font-size:.67rem; font-weight:700; color:#a8f5c8;
    background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.2);
    border-radius:10px; padding:3px 10px; letter-spacing:.05em;
}
.med-view-all { font-size:.78rem; color:#a8c4ff; font-weight:600; text-decoration:none; display:flex; align-items:center; gap:4px; }
.med-view-all:hover { color:#fff; }

/* 4 tiles */
.med-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:24px; position:relative; z-index:1; }
.med-tile {
    background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.15);
    border-radius:14px; padding:16px; transition:background .2s;
}
.med-tile:hover { background:rgba(255,255,255,.17); }
.med-tile-icon  { font-size:1.4rem; margin-bottom:10px; }
.med-tile-num   { font-size:1.8rem; font-weight:800; color:#fff; font-variant-numeric:tabular-nums; line-height:1; margin-bottom:4px; }
.med-tile-lbl   { font-size:.75rem; color:rgba(255,255,255,.6); font-weight:500; }
.med-tile-sub   { font-size:.7rem; font-weight:600; margin-top:5px; }
.msub-good   { color:#7effc0; }
.msub-warn   { color:#ffd97d; }
.msub-danger { color:#ff9b9b; }

/* bars */
.med-bars { position:relative; z-index:1; margin-bottom:18px; }
.bar-row  { margin-bottom:10px; }
.bar-label{ display:flex; justify-content:space-between; font-size:.73rem; color:rgba(255,255,255,.6); margin-bottom:5px; }
.bar-track{ background:rgba(255,255,255,.12); border-radius:8px; height:7px; overflow:hidden; }
.bar-fill { height:100%; border-radius:8px; transition:width 1.1s cubic-bezier(.22,1,.36,1); }
.bfill-green  { background:linear-gradient(90deg,#4ade80,#22c55e); }
.bfill-yellow { background:linear-gradient(90deg,#fbbf24,#f59e0b); }
.bfill-red    { background:linear-gradient(90deg,#f87171,#ef4444); }

/* category chips */
.med-cats { display:flex; flex-wrap:wrap; gap:7px; position:relative; z-index:1; }
.cat-chip {
    background:rgba(255,255,255,.11); border:1px solid rgba(255,255,255,.2);
    border-radius:20px; padding:3px 12px; font-size:.71rem; font-weight:600;
    color:rgba(255,255,255,.85); cursor:default; transition:background .15s;
}
.cat-chip:hover { background:rgba(255,255,255,.2); }

/* ── chart + activity cards ── */
.chart-card { background:#fff; border-radius:16px; padding:22px; box-shadow:0 2px 12px rgba(0,0,0,.05); height:100%; }
.cc-title { font-size:.95rem; font-weight:700; color:#1a1f36; display:flex; align-items:center; gap:8px; }
.badge-live   { font-size:.67rem; font-weight:700; color:#22a65a; background:#f0fff4; border:1px solid #b2f5d2; border-radius:10px; padding:2px 8px; }
.badge-stream { font-size:.67rem; font-weight:700; color:#2b4acb; background:#eef1ff; border:1px solid #c7d0ff; border-radius:10px; padding:2px 8px; }

.act-feed { max-height:300px; overflow-y:auto; }
.act-feed::-webkit-scrollbar { width:4px; }
.act-feed::-webkit-scrollbar-thumb { background:#e0e4f0; border-radius:4px; }
.act-item { display:flex; align-items:flex-start; gap:11px; padding:9px 0; border-bottom:1px solid #f5f7fb; animation:slideIn .35s ease; }
.act-item:last-child { border-bottom:none; }
.act-ico { width:32px; height:32px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:.82rem; flex-shrink:0; }
.act-txt { font-size:.81rem; color:#1a1f36; font-weight:500; line-height:1.3; }
.act-time{ font-size:.72rem; color:#aab0c2; margin-top:2px; }

.appt-strip { background:#fff; border-radius:16px; padding:18px 24px; box-shadow:0 2px 12px rgba(0,0,0,.05); }
</style>

@Html.Raw(@"<style>
@keyframes pulseLive {
    0%  { box-shadow:0 0 0 0   rgba(34,166,90,.6); }
    70% { box-shadow:0 0 0 8px rgba(34,166,90,0);  }
    100%{ box-shadow:0 0 0 0   rgba(34,166,90,0);  }
}
@keyframes slideIn {
    from { opacity:0; transform:translateX(10px); }
    to   { opacity:1; transform:translateX(0);    }
}
@media(max-width:768px) {
    .med-grid { grid-template-columns:repeat(2,1fr); }
