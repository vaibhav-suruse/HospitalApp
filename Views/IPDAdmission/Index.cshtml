@model List<WebApplicationSampleTest2.Models.IPDAdmissionModel>

@{
    ViewData["Title"] = "IPD Admissions";

    Func<string, string> statusBadge = (status) =>
    {
        if (status == "Admitted") return "badge bg-success";
        if (status == "Discharged") return "badge bg-secondary";
        if (status == "Cancelled") return "badge bg-warning text-dark";
        return "badge bg-light text-dark";
    };
}

@* ── Top bar: Title left | New Admission button right ── *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">IPD Admissions</h4>
    <a asp-action="Create" class="btn btn-primary">+ New Admission</a>
</div>

@* ── Alerts ── *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── Search bar — RIGHT aligned ── *@
<div class="d-flex justify-content-end mb-3">
    <form method="get" class="d-flex gap-2">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" style="width:320px;"
               placeholder="Search patient, doctor, number, status..." />
        <button class="btn btn-outline-secondary" type="submit">Search</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
        }
    </form>
</div>

@* ── Table ── *@
<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
        <thead>
            <tr style="background-color: var(--bs-primary, #4f46e5); color: #fff;">
                <th style="background-color:inherit; color:inherit;">#</th>
                <th style="background-color:inherit; color:inherit;">Admission No.</th>
                <th style="background-color:inherit; color:inherit;">Patient</th>
                <th style="background-color:inherit; color:inherit;">Doctor</th>
                <th style="background-color:inherit; color:inherit;">Admission Date</th>
                <th style="background-color:inherit; color:inherit;">Type</th>
                <th style="background-color:inherit; color:inherit;">Status</th>
                <th style="background-color:inherit; color:inherit;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">No IPD admissions found.</td>
                </tr>
            }
            else
            {
                int serial = ((int)ViewBag.CurrentPage - 1) * 6 + 1;
                foreach (var item in Model)
                {
                    <tr>
                        <td>@serial</td>
                        <td>@item.AdmissionNumber</td>
                        <td>@item.PatientName</td>
                        <td>@item.DoctorName</td>
                        <td>@item.AdmissionDateTime.ToString("dd-MMM-yyyy")</td>
                        <td>@item.AdmissionType</td>
                        <td>
                            <span class="@statusBadge(item.Status)">@item.Status</span>
                        </td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">

                                @* Details *@
                                <a asp-action="Details" asp-route-id="@item.IPDId"
                                   class="btn btn-sm btn-info text-white">
                                    <i class="ti ti-eye me-1"></i>Details
                                </a>

                                @* Edit — not available for Discharged *@
                                @if (item.Status != "Discharged")
                                {
                                    <a asp-action="Edit" asp-route-id="@item.IPDId"
                                       class="btn btn-sm btn-warning">
                                        <i class="ti ti-edit me-1"></i>Edit
                                    </a>
                                }

                                @* Soft Delete — only for Admitted *@
                                @if (item.Status == "Admitted")
                                {
                                    <form asp-action="Delete" asp-route-id="@item.IPDId"
                                          method="post" class="d-inline"
                                          onsubmit="return confirmDelete('@Html.Raw(item.PatientName)', '@item.AdmissionNumber')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="ti ti-trash me-1"></i>Delete
                                        </button>
                                    </form>
                                }

                            </div>
                        </td>
                    </tr>
                    serial++;
                }
            }
        </tbody>
    </table>
</div>

@* ── Pagination — RIGHT aligned ── *@
@if ((int)ViewBag.TotalPages > 1)
{
    <div class="d-flex justify-content-end mt-2">
        <nav>
            <ul class="pagination mb-0">
                @for (int p = 1; p <= (int)ViewBag.TotalPages; p++)
                {
                    <li class="page-item @(p == (int)ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@p"
                           asp-route-search="@ViewBag.Search">@p</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}

@section Scripts {
    <script>
        function confirmDelete(patientName, admissionNo) {
            return confirm(
                'Cancel this admission?\n\n' +
                'Patient     : ' + patientName + '\n' +
                'Admission # : ' + admissionNo + '\n\n' +
                'The allocated bed will also be freed.\n' +
                'This cannot be undone.'
            );
        }
    </script>
}
















