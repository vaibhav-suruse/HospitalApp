        //         error: function (xhr) {
        //             console.log(xhr.responseText);
        //             alert("Failed to load Reference Doctors");
        //         }
        //     });

        // });
    </script>

    @if (!Model.IsFromAppointment)
    {
        <script>
            $(document).ready(function () {

                // ================= PATIENT SEARCH =================
                $("#SearchPatient").keyup(function () {
                    let search = $(this).val();

                    if (search.length < 3) {
                        $("#patientResult").hide();
                        return;
                    }

                    $.get('/IPDAdmission/SearchPatientByMobile', { search: search }, function (res) {
                        $("#patientResult").empty();

                        if (!res || res.length === 0) {
                            $("#patientResult").append(
                                '<li class="list-group-item text-danger">Patient not found</li>');
                        } else {
                           $.each(res, function (i, item) {
                            $("#patientResult").append(`
                              <li class="list-group-item patient-item"
                                data-id="${item.id}"
                                data-name="${item.name}">
                                ${item.mobile} - ${item.name}
                              </li>
                            `);
                           });
                        }

                        $("#patientResult").show();
                    });
                });

                $(document).on("click", ".patient-item", function () {
                    var id = $(this).data("id");
                     var name = $(this).data("name");
                     $("input[name='PatientId']").val(id);
                      $("#PatientNameInput").val(name);
                    $("#patientResult").hide();
                });

                // ================= DOCTOR DROPDOWN =================
                $.get('/IPDAdmission/GetDoctors', function (data) {
                    var doctorDropdown = $('#Doctor_Id');

                    $.each(data, function (i, d) {
                        doctorDropdown.append('<option value="' + d.id + '">Dr. ' + d.name + '</option>');
                    });
                });
            });
        </script>

    }
}