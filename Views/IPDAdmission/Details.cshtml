@section Scripts {
    <script>
        @if (TempData["Success"] != null)
        {
                    <text>
                        toastr.success("@TempData["Success"]");
                    </text>
        }

        @if (TempData["Error"] != null)
        {
                    <text>
                        toastr.error("@TempData["Error"]");
                    </text>
        }


                // ── OPERATION VARIABLES ──────────────────────────────────────────
        var ipdId        = @Model.Admission.IPDId;
        var staffList    = [];
        var staffCounter = 0;
        var masterData   = { operations: [], doctors: [], nurses: [] };

        // ── LOAD ON PAGE READY ───────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', function () {
            loadOperations();
            loadMasterData();
        });

        // ── LOAD MASTER DATA FOR DROPDOWNS ──────────────────────────────
        function loadMasterData() {
            fetch('/IPDOperation/GetMasterData')
                .then(r => r.json())
                .then(data => {
                    masterData = data;

                    // Fill operations dropdown
                    var opSel = document.getElementById('ddlOperation');
                    data.operations.forEach(op => {
                        opSel.innerHTML +=
                            `<option value="${op.OperationId}"
                                data-ot="${op.OTCharge}"
                                data-surg="${op.SurgeonCharge}"
                                data-anes="${op.AnesthesiaCharge}"
                                data-def="${op.DefaultCharge}">
                                ${op.OperationName}
                                ${op.Category ? '(' + op.Category + ')' : ''}
                            </option>`;
                    });

                    // Fill doctor dropdown
                    var docSel = document.getElementById('ddlStaffDoctor');
                    data.doctors.forEach(d => {
                        docSel.innerHTML +=
                            `<option value="${d.Doctor_Id}">
                                Dr. ${d.FirstName} ${d.LastName}
                                ${d.Specialization
                                    ? ' - ' + d.Specialization : ''}
                            </option>`;
                    });

                    // Fill nurse dropdown
                    var nurseSel = document.getElementById('ddlStaffNurse');
                    data.nurses.forEach(n => {
                        nurseSel.innerHTML +=
                            `<option value="${n.NurseId}">
                                ${n.FirstName} ${n.LastName || ''}
                            </option>`;
                    });
                })
                .catch(err => console.error('Error loading master data:', err));
        }

        // ── LOAD OPERATIONS TABLE ────────────────────────────────────────
        function loadOperations() {
            fetch('/IPDOperation/GetByIPDId?ipdId=' + ipdId)
                .then(r => r.json())
                .then(ops => {
                    var body = document.getElementById('operationsTableBody');

                    if (!ops || ops.length === 0) {
                        body.innerHTML = `
                            <tr>
                                <td colspan="11"
                                    class="text-center text-muted">
                                    No operations recorded
                                </td>
                            </tr>`;
                        return;
                    }

                    body.innerHTML = '';
                    ops.forEach(op => {
                        var staffTotal = op.Staff
                            ? op.Staff.reduce((a, s) => a + s.Charge, 0)
                            : 0;
                        var staffNames = op.Staff && op.Staff.length > 0
                            ? op.Staff.map(s =>
                                `<small class="badge bg-secondary me-1">
                                    ${s.StaffType}: ${s.StaffName}
                                </small>`).join('')
                            : '-';
                        var grandTotal = op.OTCharge
                            + op.SurgeonCharge
                            + op.AnesthesiaCharge
                            + op.ActualCharge
                            + staffTotal;

                        body.innerHTML += `
                            <tr>
                                <td>
                                    ${new Date(op.OperationDate)
                                        .toLocaleDateString('en-IN')}
                                </td>
                                <td><strong>${op.OperationName}</strong></td>
                                <td>${op.SurgeonName || '-'}</td>
                                <td>${op.AnesthesistName || '-'}</td>
                                <td>${staffNames}</td>
                                <td class="text-end">
                                    ₹${op.OTCharge.toFixed(2)}
                                </td>
                                <td class="text-end">
                                    ₹${op.SurgeonCharge.toFixed(2)}
                                </td>
                                <td class="text-end">
                                    ₹${op.AnesthesiaCharge.toFixed(2)}
                                </td>
                                <td class="text-end">
                                    ₹${staffTotal.toFixed(2)}
                                </td>
                                <td class="text-end">
                                    <strong class="text-danger">
                                        ₹${grandTotal.toFixed(2)}
                                    </strong>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-danger"
                                        onclick="deleteOperation(
                                            ${op.IPDOperationId})">
                                        Del
                                    </button>
                                </td>
                            </tr>`;
                    });
                })
                .catch(err => console.error('Error loading operations:', err));
        }

        // ── SHOW MODAL ───────────────────────────────────────────────────
        function showOperationModal() {
            // Reset everything
            staffList    = [];
            staffCounter = 0;
            document.getElementById('ddlOperation').value = '';
            document.getElementById('txtOpDate').value    =
                new Date().toISOString().slice(0, 16);
            document.getElementById('txtOpNotes').value   = '';
            ['txtOTCharge', 'txtSurgCharge',
             'txtAnesCharge', 'txtActualCharge',
             'txtStaffCharge'].forEach(id => {
                document.getElementById(id).value = '0';
            });
            document.getElementById('staffTableBody').innerHTML = `
                <tr id="noStaffRow">
                    <td colspan="4" class="text-center text-muted">
                        No staff added yet
                    </td>
                </tr>`;
            calcOpTotal();
            new bootstrap.Modal(
                document.getElementById('operationModal')).show();
        }

        // ── AUTO FILL CHARGES FROM MASTER ───────────────────────────────
        function loadDefaultCharges() {
            var sel = document.getElementById('ddlOperation');
            var opt = sel.options[sel.selectedIndex];
            if (opt && opt.value) {
                document.getElementById('txtOTCharge').value =
                    opt.dataset.ot   || 0;
                document.getElementById('txtSurgCharge').value =
                    opt.dataset.surg || 0;
                document.getElementById('txtAnesCharge').value =
                    opt.dataset.anes || 0;
                document.getElementById('txtActualCharge').value =
                    opt.dataset.def  || 0;
                calcOpTotal();
            }
        }

        // ── TOGGLE DOCTOR / NURSE DROPDOWN ──────────────────────────────
        function toggleStaffInput() {
            var type    = document.getElementById('ddlStaffType').value;
            var isNurse = type === 'ScrubNurse'
                       || type === 'CirculatingNurse';
            document.getElementById('divDoctorDrop').style.display =
                isNurse ? 'none' : '';
            document.getElementById('divNurseDrop').style.display  =
                isNurse ? ''     : 'none';
        }

        // ── ADD STAFF ROW ────────────────────────────────────────────────
        function addStaff() {
            var type    = document.getElementById('ddlStaffType').value;
            var isNurse = type === 'ScrubNurse'
                       || type === 'CirculatingNurse';
            var charge  = parseFloat(
                document.getElementById('txtStaffCharge').value) || 0;

            var docSel   = document.getElementById('ddlStaffDoctor');
            var nurseSel = document.getElementById('ddlStaffNurse');

            var docId   = !isNurse && docSel.value
                ? parseInt(docSel.value) : null;
            var nurseId = isNurse && nurseSel.value
                ? parseInt(nurseSel.value) : null;

            var name = isNurse
                ? (nurseSel.options[nurseSel.selectedIndex]?.text || '')
                : (docSel.options[docSel.selectedIndex]?.text    || '');

            if (!docId && !nurseId) {
                alert('Please select a doctor or nurse');
                return;
            }

            staffCounter++;
            staffList.push({
                id:        staffCounter,
                staffType: type,
                doctorId:  docId,
                nurseId:   nurseId,
                staffName: name,
                charge:    charge
            });

            var noRow = document.getElementById('noStaffRow');
            if (noRow) noRow.remove();

            document.getElementById('staffTableBody')
                .insertAdjacentHTML('beforeend', `
                    <tr id="staffRow_${staffCounter}">
                        <td>
                            <span class="badge bg-secondary">${type}</span>
                        </td>
                        <td>${name}</td>
                        <td class="text-end">₹${charge.toFixed(2)}</td>
                        <td>
                            <button type="button"
                                    class="btn btn-sm btn-danger"
                                    onclick="removeStaff(${staffCounter})">
                                ✕
                            </button>
                        </td>
                    </tr>`);

            document.getElementById('txtStaffCharge').value = '0';
            calcOpTotal();
        }

        // ── REMOVE STAFF ROW ─────────────────────────────────────────────
        function removeStaff(id) {
            staffList = staffList.filter(x => x.id !== id);
            document.getElementById('staffRow_' + id)?.remove();
            if (staffList.length === 0) {
                document.getElementById('staffTableBody').innerHTML = `
                    <tr id="noStaffRow">
                        <td colspan="4" class="text-center text-muted">
                            No staff added yet
                        </td>
                    </tr>`;
            }
            calcOpTotal();
        }

        // ── CALCULATE TOTAL ──────────────────────────────────────────────
        function calcOpTotal() {
            var ot     = parseFloat(
                document.getElementById('txtOTCharge').value)     || 0;
            var surg   = parseFloat(
                document.getElementById('txtSurgCharge').value)   || 0;
            var anes   = parseFloat(
                document.getElementById('txtAnesCharge').value)   || 0;
            var actual = parseFloat(
                document.getElementById('txtActualCharge').value) || 0;
            var staffT = staffList.reduce((a, s) => a + s.charge, 0);

            document.getElementById('opGrandTotal')
                .innerText = (ot + surg + anes + actual + staffT).toFixed(2);
        }

        // ── SAVE OPERATION ───────────────────────────────────────────────
        function saveOperation() {
            var opSel = document.getElementById('ddlOperation');
            if (!opSel.value) {
                alert('Please select an operation'); return;
            }
            var opDate = document.getElementById('txtOpDate').value;
            if (!opDate) {
                alert('Please enter operation date'); return;
            }

            // Find surgeon + anesthetist from staff list for quick ref
            var surgeonStaff =
                staffList.find(s => s.staffType === 'Surgeon');
            var anesStaff    =
                staffList.find(s => s.staffType === 'Anesthetist');

            var payload = {
                ipdId:            ipdId,
                operationId:      parseInt(opSel.value),
                operationDate:    opDate,
                surgeonId:        surgeonStaff?.doctorId   || null,
                anesthesistId:    anesStaff?.doctorId      || null,
                otCharge:         parseFloat(
                    document.getElementById('txtOTCharge').value)     || 0,
                surgeonCharge:    parseFloat(
                    document.getElementById('txtSurgCharge').value)   || 0,
                anesthesiaCharge: parseFloat(
                    document.getElementById('txtAnesCharge').value)   || 0,
                actualCharge:     parseFloat(
                    document.getElementById('txtActualCharge').value) || 0,
                notes:
                    document.getElementById('txtOpNotes').value,
                staff: staffList.map(s => ({
                    staffType: s.staffType,
                    doctorId:  s.doctorId,
                    nurseId:   s.nurseId,
                    staffName: s.staffName,
                    charge:    s.charge
                }))
            };

            fetch('/IPDOperation/SaveOperation', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(payload)
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    bootstrap.Modal.getInstance(
                        document.getElementById('operationModal')).hide();
                    loadOperations();
                    toastr.success('Operation saved successfully!');
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(err => alert('Error: ' + err));
        }

        // ── DELETE OPERATION ─────────────────────────────────────────────
        function deleteOperation(id) {
            if (!confirm('Delete this operation?')) return;
            fetch('/IPDOperation/DeleteOperation', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ id: id, ipdId: ipdId })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    loadOperations();
                    toastr.success('Operation deleted.');
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }
    </script>
}
