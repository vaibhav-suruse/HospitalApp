@* Views/OPDBilling/_OPDBillPanel.cshtml *@
@model WebApplicationSampleTest2.Models.OPDBillVM

<div class="card border-0 shadow-sm sticky-top" style="top:80px;">
    <div class="card-header bg-primary text-white py-2">
        <h6 class="mb-0"><i class="fas fa-receipt me-2"></i>Bill Summary</h6>
    </div>

    <div class="card-body p-2">

        @if (Model.BillId.HasValue)
        {
            <div class="alert @(Model.PaymentStatus == "Paid" ? "alert-success" : "alert-warning") py-2 mb-2">
                <div><strong>Bill No: @Model.BillNumber</strong></div>
                <div>
                    Status:
                    <span class="badge @(Model.PaymentStatus == "Paid" ? "bg-success" : "bg-warning text-dark")">
                        @Model.PaymentStatus
                    </span>
                </div>
                <div>Total: <strong>₹@Model.TotalAmount.ToString("0.00")</strong></div>
                <div>Paid: <strong class="text-success">₹@Model.PaidAmount.ToString("0.00")</strong></div>
                <div>Due: <strong class="text-danger">₹@Model.DueAmount.ToString("0.00")</strong></div>
            </div>
        }

        <table class="table table-sm mb-0">
            <tr>
                <td>🩺 Consultation</td>
                <td class="text-end" id="sumConsultation">₹0.00</td>
            </tr>
            <tr>
                <td>💊 Medicines</td>
                <td class="text-end" id="sumMedicines">₹0.00</td>
            </tr>
            <tr>
                <td>⚙ Procedures</td>
                <td class="text-end" id="sumProcedures">₹0.00</td>
            </tr>
            <tr>
                <td>➕ Other</td>
                <td class="text-end" id="sumOther">₹0.00</td>
            </tr>
            <tr class="table-light">
                <td><strong>Sub Total</strong></td>
                <td class="text-end"><strong id="sumSubTotal">₹0.00</strong></td>
            </tr>
            <tr>
                <td>
                    Discount
                    <input type="number" id="txtDiscountPct"
                           class="form-control form-control-sm d-inline"
                           style="width:55px;" value="0" min="0" max="100" step="0.5"
                           onchange="recalculate()" />
                    %
                </td>
                <td class="text-end text-danger" id="sumDiscount">-₹0.00</td>
            </tr>
            <tr class="table-primary">
                <td><strong>Total</strong></td>
                <td class="text-end">
                    <strong id="sumTotal" style="font-size:16px;">₹0.00</strong>
                </td>
            </tr>
        </table>

        @if (!Model.BillId.HasValue)
        {
            <button class="btn btn-primary w-100 mt-2" onclick="saveBill()">
                <i class="fas fa-save me-1"></i> Generate Bill
            </button>
        }
        else if (Model.PaymentStatus != "Paid")
        {
            <hr />
            <h6>Collect Payment</h6>
            <div class="mb-2">
                <input type="number" id="txtPayAmount" class="form-control mb-1"
                       placeholder="Amount ₹" value="@Model.DueAmount.ToString("0.00")"
                       min="0" step="0.01" />
                <select id="ddlPayMode" class="form-control mb-1">
                    <option value="Cash">Cash</option>
                    <option value="Card">Card</option>
                    <option value="UPI">UPI</option>
                    <option value="NetBanking">Net Banking</option>
                    <option value="Cheque">Cheque</option>
                    <option value="Insurance">Insurance</option>
                </select>
                <input type="text" id="txtTransRef" class="form-control mb-1"
                       placeholder="Transaction Ref (optional)" />
                <button class="btn btn-success w-100"
                        onclick="payBill(@Model.BillId)">
                    💰 Collect Payment
                </button>
            </div>
        }
        else
        {
            <div class="alert alert-success text-center mt-2 py-2">
                <i class="fas fa-check-circle me-1"></i>
                <strong>Payment Complete!</strong><br />
                Mode: @Model.PaymentMode
            </div>
        }
    </div>
</div>
