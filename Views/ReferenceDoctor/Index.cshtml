@using WebApplicationSampleTest2.Models
@model List<ReferenceDoctorModel>

<div class="row">
    <div class="col-12">

        <!-- HEADER -->
        <div class="d-flex justify-content-end mb-3">
            <a class="btn btn-primary" asp-controller="ReferenceDoctor" asp-action="Create">
                + Add Reference Doctor
            </a>
        </div>

        <div class="card">
            <div class="card-body">

                <div>
                    <h4 class="mb-1">Reference Doctor List</h4>
                    <p class="text-muted mb-0">
                        Below is the list of all reference doctors.
                    </p>
                </div>

                <!-- SEARCH -->
                <div class="d-flex justify-content-end mb-3">
                    <form id="searchForm" method="get" asp-action="Index">
                        <input type="text"
                               name="search"
                               id="searchInput"
                               value="@ViewBag.Search"
                               class="form-control"
                               style="width:220px"
                               placeholder="Search doctor..." />
                        <input type="hidden" name="page" value="1" />
                    </form>
                </div>

                <!-- TABLE -->
                <div class="table-responsive">
                    <table class="table align-middle table-hover text-nowrap">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Doctor Name</th>
                                <th>Clinic Name</th>
                                <th>Mobile</th>
                                <th>Email</th>                              
                                <th>Percentage (%)</th>
                                <th>Address</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int serial = ((ViewBag.CurrentPage - 1) * 5) + 1;

                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@serial</td>
                                        <td>@item.DoctorName</td>
                                        <td>@item.ClinicName</td>
                                        <td>@item.MobileNumber</td>
                                        <td>@item.Email</td>
                                        <td>@item.Percentage %</td>
                                        <td>@item.Address</td>

                                        <td>

                                            <a asp-controller="ReferenceDoctor"
                                               asp-action="Edit"
                                               asp-route-id="@item.ReferenceDoctorId"
                                               class="btn btn-sm btn-primary">
                                                Edit
                                            </a>
                                            <button class="btn btn-sm btn-danger"
                                               onclick="confirmDelete(@item.ReferenceDoctorId)">
                                                Delete
                                            </button>
                                           
                                        </td>
                                    </tr>

                                    serial++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-3">
                                        No reference doctors found
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- PAGINATION -->
                @if (ViewBag.TotalPages > 1)
                {
                    <div class="d-flex justify-content-end mt-3">
                        <ul class="pagination mb-0">

                            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                                   asp-route-search="@ViewBag.Search">
                                    Previous
                                </a>
                            </li>

                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-search="@ViewBag.Search">
                                        @i
                                    </a>
                                </li>
                            }

                            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                                   asp-route-search="@ViewBag.Search">
                                    Next
                                </a>
                            </li>

                        </ul>
                    </div>
                }

            </div>
        </div>
    </div>
</div>
<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Confirmation</h5>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this Reference Doctor?
            </div>
            <div class="modal-footer">
                <form id="deleteForm" method="get">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-danger">
                        Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
<script>
    function confirmDelete(id) {

        var url = '/ReferenceDoctor/Delete/' + id;

        document.getElementById("deleteForm").action = url;

        var modal = new bootstrap.Modal(
            document.getElementById('deleteModal')
        );
        modal.show();
    }
</script>
}
